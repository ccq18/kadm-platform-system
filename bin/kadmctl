#!/usr/bin/env bash
set -euo pipefail

DEFAULT_CLUSTER="default"
DEFAULT_API_PORT="16443"
DEFAULT_CONSOLE_PORT="18080"
DEFAULT_ARGOCD_LOCAL_PORT="18081"
DEFAULT_K3S_VERSION="${KADM_DEFAULT_K3S_VERSION:-v1.36.2+k3s1}"
DEFAULT_K3S_ARCH="${KADM_DEFAULT_K3S_ARCH:-amd64}"
DEFAULT_GATEWAY_API_VERSION="v1.5.1"
DEFAULT_ARGOCD_VERSION="v3.4.4"
DEFAULT_ROLLOUTS_VERSION="v1.9.0"
DEFAULT_CILIUM_VERSION="1.19.5"
KUBECTL_REQUEST_TIMEOUT="${KADM_KUBECTL_REQUEST_TIMEOUT:-${ONECD_KUBECTL_REQUEST_TIMEOUT:-30s}}"
KUBECTL_RETRY_ATTEMPTS="${KADM_KUBECTL_RETRY_ATTEMPTS:-${ONECD_KUBECTL_RETRY_ATTEMPTS:-5}}"
KUBECTL_RETRY_DELAY="${KADM_KUBECTL_RETRY_DELAY:-${ONECD_KUBECTL_RETRY_DELAY:-5}}"
DEFAULT_GATEWAY_API_URL="https://github.com/kubernetes-sigs/gateway-api/releases/download/${DEFAULT_GATEWAY_API_VERSION}/experimental-install.yaml"
DEFAULT_ARGOCD_URL="https://raw.githubusercontent.com/argoproj/argo-cd/${DEFAULT_ARGOCD_VERSION}/manifests/install.yaml"
DEFAULT_ROLLOUTS_URL="https://github.com/argoproj/argo-rollouts/releases/download/${DEFAULT_ROLLOUTS_VERSION}/install.yaml"
DEFAULT_CILIUM_CHART_URL="https://helm.cilium.io/cilium-${DEFAULT_CILIUM_VERSION}.tgz"
DEFAULT_K3S_INSTALL_SCRIPT_URL="https://get.k3s.io"
DEFAULT_K3S_BINARY_URL="https://github.com/k3s-io/k3s/releases/download/${DEFAULT_K3S_VERSION}/k3s"
DEFAULT_K3S_AIRGAP_IMAGES_URL="https://github.com/k3s-io/k3s/releases/download/${DEFAULT_K3S_VERSION}/k3s-airgap-images-${DEFAULT_K3S_ARCH}.tar.zst"
LEGACY_GATEWAY_API_URL="https://github.com/kubernetes-sigs/gateway-api/releases/latest/download/experimental-install.yaml"
LEGACY_ARGOCD_URL="https://raw.githubusercontent.com/argoproj/argo-cd/stable/manifests/install.yaml"
LEGACY_ROLLOUTS_URL="https://github.com/argoproj/argo-rollouts/releases/latest/download/install.yaml"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORKSPACE_PARENT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
DEFAULT_ONECD_OVERLAY="${WORKSPACE_PARENT}/kadm-release-console/k8s/overlays/prod"
DEFAULT_APP_CONFIGS_DIR="${WORKSPACE_PARENT}/kadm-app-configs"
DEFAULT_HELM_VERSION="v3.15.4"
HELM_BIN=""

usage() {
  cat <<'USAGE'
kadmctl - local installer and connector for the KADM platform

Usage:
  kadmctl bootstrap <ssh-target> [--name <cluster>] [--private-ip <ip>] [--api-port <port>] [--console-port <port>] [--k3s-version <version>] [--cilium-version <version>] [--skip-components] [--dry-run|--apply]
  kadmctl deploy [--name <cluster>] [--access-host <ssh-target>] [--private-ip <ip>] [--api-port <port>] [--console-port <port>] [--k3s-version <version>] [--cilium-version <version>] [--dns-upstream <ip>]... [--skip-components] [--dry-run|--apply]
  kadmctl install-tools [--dry-run|--apply]
  kadmctl prepare-assets [--refresh] [--dry-run|--apply]
  kadmctl export-assets --output <path>
  kadmctl import-assets <path>
  kadmctl publish-release-console [--repo-dir <path>] [--tag <tag>] [--ref <branch>] [--workflow <file>] [--dry-run|--apply]
  kadmctl publish-onecd [--onecd-dir <path>] [--tag <tag>] [--ref <branch>] [--workflow <file>] [--dry-run|--apply]
  kadmctl configure-delivery [cluster] [--onecd-overlay <path>] [--app-configs-dir <path>] [--argocd-base-url <url>] [--argocd-local-port <port>] [--dry-run|--apply]
  kadmctl configure-demo-apps [cluster] [--app-configs-dir <path>] [--db-ssh-target <ssh-target>] [--db-node-ip <ip>] [--dry-run|--apply]
  kadmctl configure-cluster-dns [cluster] [--upstream <ip>]... [--dry-run|--apply]
  kadmctl connect [cluster] [--api-port <port>] [--console-port <port>] [--dry-run]
  kadmctl status [cluster] [--api-port <port>]
  kadmctl reset-node <ssh-target> [--dry-run|--apply]
  kadmctl cleanup-legacy-onecd [cluster] [--api-port <port>] [--dry-run|--apply]
  kadmctl help

Examples:
  kadmctl bootstrap root@1.2.3.4 --name home-prod --private-ip 10.0.0.11 --apply
  kadmctl deploy --name home-prod --access-host root@203.0.113.11 --private-ip 10.0.0.11 --apply
  kadmctl install-tools --apply
  kadmctl prepare-assets --apply
  kadmctl export-assets --output kadm-platform-assets.tgz
  kadmctl import-assets kadm-platform-assets.tgz
  KADM_GITHUB_TOKEN=... kadmctl publish-release-console --tag sha-1234567 --apply
  KADM_GITHUB_TOKEN=... kadmctl configure-delivery home-prod --apply
  kadmctl configure-demo-apps home-prod --app-configs-dir /path/to/kadm-app-configs --apply
  kadmctl configure-cluster-dns home-prod --upstream 1.1.1.1 --upstream 8.8.8.8 --apply
  kadmctl connect home-prod
  kadmctl status home-prod
  kadmctl reset-node root@1.2.3.4 --apply
  kadmctl cleanup-legacy-onecd home-prod --apply
  kadmctl connect --dry-run

Safety:
  bootstrap defaults to --dry-run. Remote changes require --apply.
  bootstrap consumes cached component assets. Run prepare-assets before bootstrap.
  deploy defaults to --dry-run. Local changes require --apply.
  deploy consumes cached component assets. Run prepare-assets or import-assets before deploy.
  reset-node defaults to --dry-run. Remote cleanup requires --apply.
  connect uses SSH tunnel by default; Kubernetes API does not need public exposure.
USAGE
}

die() {
  echo "error: $*" >&2
  exit 1
}

info() {
  echo "$*"
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

require_env() {
  local name="$1"
  [[ -n "${!name:-}" ]] || die "${name} is required"
}

apply_kadm_env_aliases() {
  [[ -n "${ONECD_GITHUB_TOKEN:-}" || -z "${KADM_GITHUB_TOKEN:-}" ]] || export ONECD_GITHUB_TOKEN="${KADM_GITHUB_TOKEN}"
  [[ -n "${ONECD_GHCR_USERNAME:-}" || -z "${KADM_GHCR_USERNAME:-}" ]] || export ONECD_GHCR_USERNAME="${KADM_GHCR_USERNAME}"
  [[ -n "${ONECD_GHCR_TOKEN:-}" || -z "${KADM_GHCR_TOKEN:-}" ]] || export ONECD_GHCR_TOKEN="${KADM_GHCR_TOKEN}"
  [[ -n "${ONECD_ARGOCD_TOKEN:-}" || -z "${KADM_ARGOCD_TOKEN:-}" ]] || export ONECD_ARGOCD_TOKEN="${KADM_ARGOCD_TOKEN}"
}

resolve_ipv4_address() {
  local host="$1"
  if command -v getent >/dev/null 2>&1; then
    getent ahostsv4 "${host}" 2>/dev/null | awk 'NR == 1 { print $1; exit }'
    return 0
  fi
  return 1
}

retry_command() {
  local attempts="$1"
  local delay="$2"
  shift 2

  local i
  for ((i = 1; i <= attempts; i++)); do
    if "$@"; then
      return 0
    fi
    if [[ "${i}" -eq "${attempts}" ]]; then
      return 1
    fi
    sleep "${delay}"
  done
}

validate_cluster_name() {
  local value="$1"
  [[ "${value}" =~ ^[A-Za-z0-9._-]+$ ]] || die "cluster name must contain only letters, numbers, dot, underscore, or dash"
}

validate_image_repo() {
  local value="$1"
  [[ "${value}" =~ ^[A-Za-z0-9._/-]+$ ]] || die "image repo must contain only letters, numbers, dot, underscore, slash, or dash"
}

validate_image_tag() {
  local value="$1"
  [[ "${value}" =~ ^[A-Za-z0-9._-]+$ ]] || die "image tag must contain only letters, numbers, dot, underscore, or dash"
}

validate_git_ref() {
  local value="$1"
  [[ "${value}" =~ ^[A-Za-z0-9._/-]+$ ]] || die "git ref contains unsupported characters"
}

validate_port() {
  local value="$1"
  [[ "${value}" =~ ^[0-9]+$ ]] || die "port must be numeric: ${value}"
  (( value >= 1 && value <= 65535 )) || die "port out of range: ${value}"
}

validate_ssh_target() {
  local value="$1"
  [[ "${value}" =~ ^[A-Za-z0-9._~@:%+-]+$ ]] || die "ssh target contains unsupported characters"
}

validate_optional_machine_value() {
  local label="$1"
  local value="$2"
  [[ -z "${value}" || "${value}" =~ ^[A-Za-z0-9._:+-]+$ ]] || die "${label} contains unsupported characters"
}

state_root() {
  echo "${HOME}/.kadm"
}

legacy_state_root() {
  echo "${HOME}/.onecd"
}

kubeconfig_root() {
  echo "${HOME}/.kube/kadm"
}

legacy_kubeconfig_root() {
  echo "${HOME}/.kube/onecd"
}

ensure_local_state_migrated() {
  if [[ -d "$(legacy_state_root)" && ! -e "$(state_root)" ]]; then
    mkdir -p "$(dirname "$(state_root)")"
    mv "$(legacy_state_root)" "$(state_root)"
  fi
  if [[ -d "$(legacy_kubeconfig_root)" && ! -e "$(kubeconfig_root)" ]]; then
    mkdir -p "$(dirname "$(kubeconfig_root)")"
    mv "$(legacy_kubeconfig_root)" "$(kubeconfig_root)"
  fi
}

tool_dir() {
  ensure_local_state_migrated
  echo "$(state_root)/bin"
}

cache_dir() {
  ensure_local_state_migrated
  echo "$(state_root)/cache"
}

manifest_cache_dir() {
  echo "$(cache_dir)/manifests"
}

chart_cache_dir() {
  echo "$(cache_dir)/charts"
}

cilium_chart_path() {
  local version="$1"
  echo "$(chart_cache_dir)/cilium-${version}.tgz"
}

k3s_cache_dir() {
  echo "$(cache_dir)/k3s"
}

k3s_install_script_path() {
  local version="$1"
  echo "$(k3s_cache_dir)/install-${version}.sh"
}

k3s_binary_path() {
  local version="$1"
  echo "$(k3s_cache_dir)/k3s-${version}"
}

k3s_airgap_images_path() {
  local version="$1"
  echo "$(k3s_cache_dir)/k3s-airgap-images-${version}-${DEFAULT_K3S_ARCH}.tar.zst"
}

detect_platform() {
  local os arch
  os="$(uname -s)"
  arch="$(uname -m)"
  case "${os}:${arch}" in
    Darwin:arm64) echo "darwin-arm64" ;;
    Darwin:x86_64) echo "darwin-amd64" ;;
    Linux:x86_64) echo "linux-amd64" ;;
    Linux:aarch64|Linux:arm64) echo "linux-arm64" ;;
    *) die "unsupported local platform for tool install: ${os}/${arch}" ;;
  esac
}

cmd_install_tools() {
  local apply=0
  local helm_version="${DEFAULT_HELM_VERSION}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --helm-version)
        helm_version="${2:-}"
        shift 2
        ;;
      --apply)
        apply=1
        shift
        ;;
      --dry-run)
        apply=0
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        die "unknown install-tools option: $1"
        ;;
    esac
  done

  local dir platform
  dir="$(tool_dir)"
  platform="$(detect_platform)"

  if [[ "${apply}" -ne 1 ]]; then
    info "DRY RUN: local tools will not be installed"
    info "tool: helm ${helm_version}"
    info "platform: ${platform}"
    info "target dir: ${dir}"
    return 0
  fi

  install_helm "${helm_version}" "${platform}" "${dir}"
}

cmd_reset_node() {
  local ssh_target=""
  local apply=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --apply)
        apply=1
        shift
        ;;
      --dry-run)
        apply=0
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      --*)
        die "unknown reset-node option: $1"
        ;;
      *)
        if [[ -n "${ssh_target}" ]]; then
          die "unexpected reset-node argument: $1"
        fi
        ssh_target="$1"
        shift
        ;;
    esac
  done

  [[ -n "${ssh_target}" ]] || die "reset-node requires an ssh target, for example root@1.2.3.4"
  validate_ssh_target "${ssh_target}"

  if [[ "${apply}" -ne 1 ]]; then
    info "DRY RUN: no remote cleanup will be made"
    info "target: ${ssh_target}"
    info "removes: K3s server/agent services and data directories"
    return 0
  fi

  require_command ssh
  info "Resetting node ${ssh_target}"
  ssh "${ssh_target}" sudo sh -s <<'REMOTE'
set -eu

if command -v k3s-uninstall.sh >/dev/null 2>&1; then
  k3s-uninstall.sh || true
fi

if command -v k3s-agent-uninstall.sh >/dev/null 2>&1; then
  k3s-agent-uninstall.sh || true
fi

systemctl stop k3s >/dev/null 2>&1 || true
systemctl stop k3s-agent >/dev/null 2>&1 || true
systemctl disable k3s >/dev/null 2>&1 || true
systemctl disable k3s-agent >/dev/null 2>&1 || true

if command -v iptables-save >/dev/null 2>&1 && command -v iptables-restore >/dev/null 2>&1; then
  iptables-save | grep -v CILIUM_ | grep -v OLD_CILIUM_ | grep -v KUBE- | grep -v CNI- | grep -iv flannel | iptables-restore || true
fi
if command -v ip6tables-save >/dev/null 2>&1 && command -v ip6tables-restore >/dev/null 2>&1; then
  ip6tables-save | grep -v CILIUM_ | grep -v OLD_CILIUM_ | grep -v KUBE- | grep -v CNI- | grep -iv flannel | ip6tables-restore || true
fi

rm -rf \
  /etc/rancher/k3s \
  /var/lib/rancher/k3s \
  /var/lib/kubelet \
  /var/lib/cni \
  /etc/cni/net.d \
  /opt/cni/bin \
  /opt/kadm \
  /run/flannel \
  /var/run/flannel
REMOTE
  info "node reset completed"
}

cmd_prepare_assets() {
  local apply=0
  local refresh=0
  local k3s_version="${DEFAULT_K3S_VERSION}"
  local gateway_api_url="${DEFAULT_GATEWAY_API_URL}"
  local argocd_url="${DEFAULT_ARGOCD_URL}"
  local rollouts_url="${DEFAULT_ROLLOUTS_URL}"
  local cilium_version="${DEFAULT_CILIUM_VERSION}"
  local cilium_chart_url="${DEFAULT_CILIUM_CHART_URL}"
  local k3s_install_script_url="${DEFAULT_K3S_INSTALL_SCRIPT_URL}"
  local k3s_binary_url=""
  local k3s_airgap_images_url=""

  k3s_binary_url="https://github.com/k3s-io/k3s/releases/download/${k3s_version}/k3s"
  k3s_airgap_images_url="https://github.com/k3s-io/k3s/releases/download/${k3s_version}/k3s-airgap-images-${DEFAULT_K3S_ARCH}.tar.zst"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --refresh)
        refresh=1
        shift
        ;;
      --k3s-version)
        k3s_version="${2:-}"
        k3s_binary_url="https://github.com/k3s-io/k3s/releases/download/${k3s_version}/k3s"
        k3s_airgap_images_url="https://github.com/k3s-io/k3s/releases/download/${k3s_version}/k3s-airgap-images-${DEFAULT_K3S_ARCH}.tar.zst"
        shift 2
        ;;
      --gateway-api-url)
        gateway_api_url="${2:-}"
        shift 2
        ;;
      --argocd-url)
        argocd_url="${2:-}"
        shift 2
        ;;
      --rollouts-url)
        rollouts_url="${2:-}"
        shift 2
        ;;
      --cilium-version)
        cilium_version="${2:-}"
        cilium_chart_url="https://helm.cilium.io/cilium-${cilium_version}.tgz"
        shift 2
        ;;
      --cilium-chart-url)
        cilium_chart_url="${2:-}"
        shift 2
        ;;
      --apply)
        apply=1
        shift
        ;;
      --dry-run)
        apply=0
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        die "unknown prepare-assets option: $1"
        ;;
    esac
  done

  validate_optional_machine_value "k3s version" "${k3s_version}"
  validate_optional_machine_value "cilium version" "${cilium_version}"

  local gateway_path argocd_path rollouts_path cilium_chart_path_value k3s_install_path k3s_binary_path_value k3s_airgap_path
  gateway_path="$(manifest_cache_path "${gateway_api_url}")"
  argocd_path="$(manifest_cache_path "${argocd_url}")"
  rollouts_path="$(manifest_cache_path "${rollouts_url}")"
  cilium_chart_path_value="$(cilium_chart_path "${cilium_version}")"
  k3s_install_path="$(k3s_install_script_path "${k3s_version}")"
  k3s_binary_path_value="$(k3s_binary_path "${k3s_version}")"
  k3s_airgap_path="$(k3s_airgap_images_path "${k3s_version}")"

  if [[ "${apply}" -ne 1 ]]; then
    info "DRY RUN: installer assets will not be downloaded"
    info "K3s install script: ${k3s_install_script_url}"
    info "K3s binary: ${k3s_binary_url}"
    info "K3s airgap images: ${k3s_airgap_images_url}"
    info "Gateway API manifest: ${gateway_api_url}"
    info "Argo CD manifest: ${argocd_url}"
    info "Argo Rollouts manifest: ${rollouts_url}"
    info "Cilium chart: ${cilium_chart_url}"
    info "cache: ${k3s_install_path}"
    info "cache: ${k3s_binary_path_value}"
    info "cache: ${k3s_airgap_path}"
    info "cache: ${gateway_path}"
    info "cache: ${argocd_path}"
    info "cache: ${rollouts_path}"
    info "cache: ${cilium_chart_path_value}"
    return 0
  fi

  download_file_to_cache "${k3s_install_script_url}" "${k3s_install_path}" "${refresh}" "K3s install script"
  download_file_to_cache "${k3s_binary_url}" "${k3s_binary_path_value}" "${refresh}" "K3s binary"
  download_file_to_cache "${k3s_airgap_images_url}" "${k3s_airgap_path}" "${refresh}" "K3s airgap images"
  prepare_manifest_asset_with_legacy "${gateway_api_url}" "${refresh}" "Gateway API manifest" "gateway.networking.k8s.io/channel: experimental" "${LEGACY_GATEWAY_API_URL}"
  prepare_manifest_asset_with_legacy "${argocd_url}" "${refresh}" "Argo CD manifest" "quay.io/argoproj/argocd:${DEFAULT_ARGOCD_VERSION}" "${LEGACY_ARGOCD_URL}"
  prepare_manifest_asset_with_legacy "${rollouts_url}" "${refresh}" "Argo Rollouts manifest" "quay.io/argoproj/argo-rollouts:${DEFAULT_ROLLOUTS_VERSION}" "${LEGACY_ROLLOUTS_URL}"
  download_file_to_cache "${cilium_chart_url}" "${cilium_chart_path_value}" "${refresh}" "Cilium chart"

  info "installer assets are ready"
  info "next: kadmctl bootstrap <ssh-target> --apply"
}

cmd_export_assets() {
  local output=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --output)
        output="${2:-}"
        shift 2
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        die "unknown export-assets option: $1"
        ;;
    esac
  done

  [[ -n "${output}" ]] || die "export-assets requires --output <path>"
  require_command tar
  require_default_assets

  mkdir -p "$(dirname "${output}")"
  tar -czf "${output}" -C "$(state_root)" cache
  chmod 600 "${output}"
  info "offline asset bundle written: ${output}"
}

cmd_import_assets() {
  local archive="${1:-}"
  local archive_listing
  [[ -n "${archive}" ]] || die "import-assets requires a bundle path"
  [[ $# -eq 1 ]] || die "unexpected import-assets arguments"
  [[ -f "${archive}" ]] || die "offline asset bundle not found: ${archive}"
  require_command tar

  archive_listing="$(tar -tzf "${archive}")"
  if ! printf '%s\n' "${archive_listing}" | awk '
    /^cache\/manifests\// { manifests = 1 }
    /^cache\/charts\// { charts = 1 }
    END { exit !(manifests && charts) }
  '; then
    die "offline asset bundle must contain cache/manifests and cache/charts entries"
  fi

  mkdir -p "$(state_root)"
  tar -xzf "${archive}" -C "$(state_root)"
  require_default_assets
  info "offline asset bundle imported: ${archive}"
}

install_helm() {
  local helm_version="$1"
  local platform="$2"
  local dir="$3"
  local target="${dir}/helm"

  require_command curl
  require_command tar
  require_command mktemp

  if [[ -x "${target}" ]]; then
    HELM_BIN="${target}"
    info "helm already installed: ${target}"
    return 0
  fi

  local tmp
  tmp="$(mktemp -d)"
  mkdir -p "${dir}"

  local archive="${tmp}/helm.tgz"
  local url="https://get.helm.sh/helm-${helm_version}-${platform}.tar.gz"
  info "Installing helm ${helm_version} for ${platform} into ${dir}"
  curl -fsSL "${url}" -o "${archive}"
  tar -xzf "${archive}" -C "${tmp}"
  cp "${tmp}/${platform}/helm" "${target}"
  chmod 700 "${target}"
  rm -rf "${tmp}"
  HELM_BIN="${target}"
}

ensure_helm() {
  if command -v helm >/dev/null 2>&1; then
    HELM_BIN="$(command -v helm)"
    return 0
  fi

  local bundled
  bundled="$(tool_dir)/helm"
  if [[ -x "${bundled}" ]]; then
    HELM_BIN="${bundled}"
    return 0
  fi

  install_helm "${DEFAULT_HELM_VERSION}" "$(detect_platform)" "$(tool_dir)"
}

is_remote_url() {
  [[ "$1" == http://* || "$1" == https://* ]]
}

manifest_cache_path() {
  local source="$1"
  local safe
  safe="$(printf '%s' "${source}" | tr -c 'A-Za-z0-9._-' '_' | cut -c1-180)"
  echo "$(manifest_cache_dir)/${safe}.yaml"
}

download_manifest_to_cache() {
  local source="$1"
  local target="$2"
  local refresh="${3:-0}"
  local tmp="${target}.tmp"

  require_command curl
  mkdir -p "$(dirname "${target}")"

  if [[ "${refresh}" -ne 1 && -s "${target}" ]]; then
    info "Using cached manifest: ${target}"
    return 0
  fi

  if retry_command 5 10 curl --http1.1 -fsSL --connect-timeout 30 --max-time 240 "${source}" -o "${tmp}"; then
    [[ -s "${tmp}" ]] || die "downloaded manifest is empty: ${source}"
    mv "${tmp}" "${target}"
    chmod 600 "${target}"
    return 0
  fi

  rm -f "${tmp}"
  if [[ -s "${target}" ]]; then
    info "manifest download failed, using cached copy: ${target}"
    return 0
  fi

  die "failed to download manifest: ${source}"
}

materialize_manifest() {
  local source="$1"
  local out_var="$2"
  local path

  if is_remote_url "${source}"; then
    path="$(manifest_cache_path "${source}")"
    info "Caching manifest: ${source}"
    download_manifest_to_cache "${source}" "${path}"
  else
    path="${source}"
    [[ -f "${path}" ]] || die "manifest file not found: ${path}"
  fi

  printf -v "${out_var}" '%s' "${path}"
}

prepare_manifest_asset() {
  local source="$1"
  local refresh="$2"
  local path
  path="$(manifest_cache_path "${source}")"
  info "Preparing manifest: ${source}"
  download_manifest_to_cache "${source}" "${path}" "${refresh}"
}

prepare_manifest_asset_with_legacy() {
  local source="$1"
  local refresh="$2"
  local label="$3"
  local expected_marker="$4"
  shift 4

  local target legacy legacy_path
  target="$(manifest_cache_path "${source}")"

  if [[ "${refresh}" -ne 1 && -s "${target}" ]]; then
    info "Using cached ${label}: ${target}"
    return 0
  fi

  if [[ "${refresh}" -ne 1 ]]; then
    for legacy in "$@"; do
      legacy_path="$(manifest_cache_path "${legacy}")"
      if [[ -s "${legacy_path}" ]] && grep -Fq "${expected_marker}" "${legacy_path}"; then
        mkdir -p "$(dirname "${target}")"
        cp "${legacy_path}" "${target}"
        chmod 600 "${target}"
        info "Using compatible cached ${label}: ${legacy_path}"
        return 0
      fi
    done
  fi

  info "Preparing manifest: ${source}"
  download_manifest_to_cache "${source}" "${target}" "${refresh}"
}

cached_manifest_asset() {
  local source="$1"
  local label="$2"
  local out_var="$3"
  local path

  if is_remote_url "${source}"; then
    path="$(manifest_cache_path "${source}")"
  else
    path="${source}"
  fi

  require_cached_file "${path}" "${label}"
  info "Using cached ${label}: ${path}"
  printf -v "${out_var}" '%s' "${path}"
}

download_file_to_cache() {
  local source="$1"
  local target="$2"
  local refresh="${3:-0}"
  local label="$4"
  local tmp="${target}.tmp"

  require_command curl
  mkdir -p "$(dirname "${target}")"

  if [[ "${refresh}" -ne 1 && -s "${target}" ]]; then
    info "Using cached ${label}: ${target}"
    return 0
  fi

  info "Downloading ${label}: ${source}"
  if retry_command 5 10 curl --http1.1 -fsSL --connect-timeout 30 --max-time 240 "${source}" -o "${tmp}"; then
    [[ -s "${tmp}" ]] || die "downloaded ${label} is empty: ${source}"
    mv "${tmp}" "${target}"
    chmod 600 "${target}"
    return 0
  fi

  rm -f "${tmp}"
  die "failed to download ${label}: ${source}"
}

require_cached_file() {
  local path="$1"
  local label="$2"
  [[ -s "${path}" ]] || die "missing cached ${label}: ${path}. Run kadmctl prepare-assets --apply before bootstrap."
}

require_default_assets() {
  local gateway_path argocd_path rollouts_path cilium_path
  gateway_path="$(manifest_cache_path "${DEFAULT_GATEWAY_API_URL}")"
  argocd_path="$(manifest_cache_path "${DEFAULT_ARGOCD_URL}")"
  rollouts_path="$(manifest_cache_path "${DEFAULT_ROLLOUTS_URL}")"
  cilium_path="$(cilium_chart_path "${DEFAULT_CILIUM_VERSION}")"

  require_cached_file "${gateway_path}" "Gateway API manifest"
  require_cached_file "${argocd_path}" "Argo CD manifest"
  require_cached_file "${rollouts_path}" "Argo Rollouts manifest"
  require_cached_file "${cilium_path}" "Cilium chart"
}

require_local_k3s_assets() {
  local version="$1"
  require_cached_file "$(k3s_install_script_path "${version}")" "K3s install script"
  require_cached_file "$(k3s_binary_path "${version}")" "K3s binary"
  require_cached_file "$(k3s_airgap_images_path "${version}")" "K3s airgap images"
}

detect_local_private_ip() {
  if command -v ip >/dev/null 2>&1; then
    ip -o -4 route show to default 2>/dev/null | awk '{print $7; exit}'
    return 0
  fi
  return 1
}

profile_dir() {
  local cluster="$1"
  ensure_local_state_migrated
  echo "$(state_root)/clusters/${cluster}"
}

profile_path() {
  local cluster="$1"
  echo "$(profile_dir "${cluster}")/cluster.env"
}

kubeconfig_path_for() {
  local cluster="$1"
  ensure_local_state_migrated
  echo "$(kubeconfig_root)/${cluster}.yaml"
}

write_profile() {
  local cluster="$1"
  local master_ssh="$2"
  local private_ip="$3"
  local kubeconfig_path="$4"
  local api_port="$5"
  local console_port="$6"
  local join_server_url="$7"
  local join_token="$8"

  mkdir -p "$(profile_dir "${cluster}")"
  cat > "$(profile_path "${cluster}")" <<PROFILE
CLUSTER_NAME=${cluster}
MASTER_SSH=${master_ssh}
MASTER_PRIVATE_IP=${private_ip}
KUBECONFIG_PATH=${kubeconfig_path}
API_LOCAL_PORT=${api_port}
CONSOLE_LOCAL_PORT=${console_port}
K3S_JOIN_SERVER_URL=${join_server_url}
K3S_JOIN_TOKEN=${join_token}
PROFILE
  chmod 600 "$(profile_path "${cluster}")"
}

load_profile() {
  local cluster="$1"
  local path legacy_path expected_kubeconfig legacy_kubeconfig_path
  ensure_local_state_migrated
  path="$(profile_path "${cluster}")"
  legacy_path="$(legacy_state_root)/clusters/${cluster}/cluster.env"
  if [[ ! -f "${path}" && -f "${legacy_path}" ]]; then
    mkdir -p "$(dirname "${path}")"
    mv "${legacy_path}" "${path}"
  fi
  [[ -f "${path}" ]] || die "cluster profile not found: ${path}. Run kadmctl deploy or kadmctl bootstrap first."
  # shellcheck disable=SC1090
  source "${path}"

  expected_kubeconfig="$(kubeconfig_path_for "${cluster}")"
  legacy_kubeconfig_path="$(legacy_kubeconfig_root)/${cluster}.yaml"
  if [[ ! -f "${expected_kubeconfig}" && -f "${legacy_kubeconfig_path}" ]]; then
    mkdir -p "$(dirname "${expected_kubeconfig}")"
    mv "${legacy_kubeconfig_path}" "${expected_kubeconfig}"
  fi
  if [[ "${KUBECONFIG_PATH:-}" != "${expected_kubeconfig}" ]]; then
    KUBECONFIG_PATH="${expected_kubeconfig}"
    write_profile "${cluster}" "${MASTER_SSH}" "${MASTER_PRIVATE_IP}" "${KUBECONFIG_PATH}" "${API_LOCAL_PORT}" "${CONSOLE_LOCAL_PORT}" "${K3S_JOIN_SERVER_URL:-}" "${K3S_JOIN_TOKEN:-}"
  fi
}

rewrite_kubeconfig_for_tunnel() {
  local source_file="$1"
  local target_file="$2"
  local api_port="$3"

  mkdir -p "$(dirname "${target_file}")"
  sed -E "s#server: https://[^[:space:]]+#server: https://127.0.0.1:${api_port}#" "${source_file}" > "${target_file}"
  chmod 600 "${target_file}"
}

bootstrap_remote_k3s() {
  local ssh_target="$1"
  local private_ip="$2"
  local k3s_version="$3"

  local version_env=""
  if [[ -n "${k3s_version}" ]]; then
    version_env="ONECD_K3S_VERSION=${k3s_version}"
  fi

  ssh "${ssh_target}" "sudo ONECD_PRIVATE_IP='${private_ip}' ${version_env} sh -s" <<'REMOTE'
set -eu

if command -v k3s >/dev/null 2>&1; then
  echo "k3s already installed; leaving existing installation in place"
  exit 0
fi

args="server --cluster-init --flannel-backend=none --disable-network-policy --disable-kube-proxy --disable=traefik --disable=servicelb --write-kubeconfig-mode=0600"

if [ -n "${ONECD_PRIVATE_IP:-}" ]; then
  args="${args} --node-ip ${ONECD_PRIVATE_IP} --advertise-address ${ONECD_PRIVATE_IP}"
fi

if [ -n "${ONECD_K3S_VERSION:-}" ]; then
  curl -sfL https://get.k3s.io | INSTALL_K3S_VERSION="${ONECD_K3S_VERSION}" sh -s - ${args}
else
  curl -sfL https://get.k3s.io | sh -s - ${args}
fi
REMOTE
}

fetch_remote_kubeconfig() {
  local ssh_target="$1"
  local output_file="$2"
  ssh "${ssh_target}" "sudo cat /etc/rancher/k3s/k3s.yaml" > "${output_file}"
}

fetch_remote_join_token() {
  local ssh_target="$1"
  ssh "${ssh_target}" "sudo cat /var/lib/rancher/k3s/server/node-token"
}

install_local_k3s() {
  local private_ip="$1"
  local k3s_version="$2"
  local install_script binary airgap_images
  install_script="$(k3s_install_script_path "${k3s_version}")"
  binary="$(k3s_binary_path "${k3s_version}")"
  airgap_images="$(k3s_airgap_images_path "${k3s_version}")"

  require_local_k3s_assets "${k3s_version}"
  info "Using cached K3s install script: ${install_script}"
  info "Using cached K3s binary: ${binary}"
  info "Using cached K3s airgap images: ${airgap_images}"

  sudo env \
    KADM_K3S_PRIVATE_IP="${private_ip}" \
    KADM_K3S_VERSION="${k3s_version}" \
    KADM_K3S_INSTALL_SCRIPT="${install_script}" \
    KADM_K3S_BINARY="${binary}" \
    KADM_K3S_AIRGAP_IMAGES="${airgap_images}" \
    sh -s <<'LOCAL'
set -eu

if command -v k3s >/dev/null 2>&1; then
  echo "k3s already installed; leaving existing installation in place"
  exit 0
fi

install -D -m 0755 "${KADM_K3S_BINARY}" /usr/local/bin/k3s
mkdir -p /var/lib/rancher/k3s/agent/images
install -D -m 0644 "${KADM_K3S_AIRGAP_IMAGES}" "/var/lib/rancher/k3s/agent/images/$(basename "${KADM_K3S_AIRGAP_IMAGES}")"

export INSTALL_K3S_SKIP_DOWNLOAD=true
export INSTALL_K3S_BIN_DIR=/usr/local/bin

args="server --cluster-init --flannel-backend=none --disable-network-policy --disable-kube-proxy --disable=traefik --disable=servicelb --write-kubeconfig-mode=0600"
if [ -n "${KADM_K3S_PRIVATE_IP:-}" ]; then
  args="${args} --node-ip ${KADM_K3S_PRIVATE_IP} --advertise-address ${KADM_K3S_PRIVATE_IP}"
fi

INSTALL_K3S_VERSION="${KADM_K3S_VERSION}" sh "${KADM_K3S_INSTALL_SCRIPT}" ${args}
LOCAL
}

fetch_local_kubeconfig() {
  local output_file="$1"
  sudo cat /etc/rancher/k3s/k3s.yaml > "${output_file}"
}

fetch_local_join_token() {
  sudo cat /var/lib/rancher/k3s/server/node-token
}

copy_local_kubeconfig() {
  local source_file="$1"
  local target_file="$2"

  mkdir -p "$(dirname "${target_file}")"
  cp "${source_file}" "${target_file}"
  chmod 600 "${target_file}"
}

ssh_host_part() {
  local ssh_target="$1"
  local without_user="${ssh_target##*@}"
  echo "${without_user%%:*}"
}

local_ipv4_addresses() {
  if command -v ip >/dev/null 2>&1; then
    ip -o -4 addr show scope global 2>/dev/null | awk '{print $4}' | cut -d/ -f1
    return 0
  fi
  hostname -I 2>/dev/null | tr ' ' '\n'
}

is_local_address() {
  local host="$1"
  [[ -n "${host}" ]] || return 1
  [[ "${host}" == "localhost" || "${host}" == "127.0.0.1" ]] && return 0
  local ip
  while read -r ip; do
    [[ -n "${ip}" ]] || continue
    [[ "${host}" == "${ip}" ]] && return 0
  done < <(local_ipv4_addresses)
  return 1
}

is_local_ssh_target() {
  local ssh_target="$1"
  is_local_address "$(ssh_host_part "${ssh_target}")"
}

kubectl_for() {
  local kubeconfig_path="$1"
  shift
  kubectl --kubeconfig "${kubeconfig_path}" --request-timeout="${KUBECTL_REQUEST_TIMEOUT}" "$@"
}

kubectl_retry() {
  local kubeconfig_path="$1"
  shift
  retry_command "${KUBECTL_RETRY_ATTEMPTS}" "${KUBECTL_RETRY_DELAY}" kubectl_for "${kubeconfig_path}" "$@"
}

kubectl_apply_retry() {
  local kubeconfig_path="$1"
  shift
  kubectl_retry "${kubeconfig_path}" apply "$@"
}

create_namespace_if_missing() {
  local kubeconfig_path="$1"
  local namespace="$2"
  local manifest status
  manifest="$(mktemp)"
  kubectl_for "${kubeconfig_path}" create namespace "${namespace}" --dry-run=client -o yaml > "${manifest}"
  status=0
  kubectl_apply_retry "${kubeconfig_path}" -f "${manifest}" || status="$?"
  rm -f "${manifest}"
  return "${status}"
}

wait_for_kube_api() {
  local kubeconfig_path="$1"
  local tunnel_pid="${2:-}"
  local attempts=90
  local i
  for ((i = 1; i <= attempts; i++)); do
    if [[ -n "${tunnel_pid}" ]] && ! kill -0 "${tunnel_pid}" >/dev/null 2>&1; then
      die "Kubernetes API tunnel exited before the API became ready"
    fi
    if kubectl_for "${kubeconfig_path}" get --raw=/readyz >/dev/null 2>&1; then
      return 0
    fi
    sleep 2
  done
  die "Kubernetes API did not become ready in time"
}

wait_for_crds_established() {
  local kubeconfig_path="$1"
  shift

  local crd
  for crd in "$@"; do
    kubectl_retry "${kubeconfig_path}" wait --for=condition=Established "crd/${crd}" --timeout=180s
  done
}

wait_for_daemonset_ready() {
  local kubeconfig_path="$1"
  local namespace="$2"
  local name="$3"
  local timeout_seconds="$4"
  local deadline=$((SECONDS + timeout_seconds))
  local state ready desired

  while (( SECONDS < deadline )); do
    state="$(kubectl_for "${kubeconfig_path}" -n "${namespace}" get daemonset "${name}" -o jsonpath='{.status.numberReady} {.status.desiredNumberScheduled}' 2>/dev/null || true)"
    ready="${state%% *}"
    desired="${state##* }"
    ready="${ready:-0}"
    desired="${desired:-0}"
    if [[ "${desired}" =~ ^[0-9]+$ && "${ready}" =~ ^[0-9]+$ && "${desired}" -gt 0 && "${ready}" -ge "${desired}" ]]; then
      info "daemonset/${name} ready: ${ready}/${desired}"
      return 0
    fi
    info "waiting for daemonset/${name}: ${ready}/${desired}"
    sleep 5
  done

  die "timed out waiting for daemonset/${name}"
}

wait_for_deployment_ready() {
  local kubeconfig_path="$1"
  local namespace="$2"
  local name="$3"
  local timeout_seconds="$4"
  local deadline=$((SECONDS + timeout_seconds))
  local state available desired

  while (( SECONDS < deadline )); do
    state="$(kubectl_for "${kubeconfig_path}" -n "${namespace}" get deploy "${name}" -o jsonpath='{.status.availableReplicas} {.spec.replicas}' 2>/dev/null || true)"
    available="${state%% *}"
    desired="${state##* }"
    available="${available:-0}"
    desired="${desired:-0}"
    if [[ "${desired}" =~ ^[0-9]+$ && "${available}" =~ ^[0-9]+$ && "${desired}" -gt 0 && "${available}" -ge "${desired}" ]]; then
      info "deployment/${name} ready: ${available}/${desired}"
      return 0
    fi
    info "waiting for deployment/${name}: ${available}/${desired}"
    sleep 5
  done

  die "timed out waiting for deployment/${name}"
}

allow_gateway_api_experimental_upgrade() {
  local kubeconfig_path="$1"
  local gateway_api_manifest="$2"

  if ! grep -Fq "gateway.networking.k8s.io/channel: experimental" "${gateway_api_manifest}"; then
    return 0
  fi

  info "Allowing Gateway API experimental CRD upgrade"
  kubectl_retry "${kubeconfig_path}" delete validatingadmissionpolicybinding safe-upgrades.gateway.networking.k8s.io --ignore-not-found
  kubectl_retry "${kubeconfig_path}" delete validatingadmissionpolicy safe-upgrades.gateway.networking.k8s.io --ignore-not-found
}

start_api_tunnel() {
  local ssh_target="$1"
  local api_port="$2"

  ssh -N -L "${api_port}:127.0.0.1:6443" -o ExitOnForwardFailure=yes "${ssh_target}" >/dev/null 2>&1 &
  local tunnel_pid="$!"
  sleep 1
  if ! kill -0 "${tunnel_pid}" >/dev/null 2>&1; then
    die "Kubernetes API tunnel failed to start"
  fi
  echo "${tunnel_pid}"
}

stop_pid() {
  local pid="$1"
  [[ -n "${pid}" ]] || return 0
  kill "${pid}" >/dev/null 2>&1 || true
  wait "${pid}" >/dev/null 2>&1 || true
}

start_service_port_forward() {
  local kubeconfig_path="$1"
  local namespace="$2"
  local service="$3"
  local local_port="$4"
  local remote_port="$5"
  local log_file
  log_file="$(mktemp)"

  kubectl_for "${kubeconfig_path}" -n "${namespace}" port-forward "svc/${service}" "${local_port}:${remote_port}" >"${log_file}" 2>&1 &
  local port_forward_pid="$!"

  local i
  for ((i = 1; i <= 30; i++)); do
    if ! kill -0 "${port_forward_pid}" >/dev/null 2>&1; then
      cat "${log_file}" >&2 || true
      rm -f "${log_file}"
      die "port-forward failed to start for ${namespace}/${service}"
    fi
    if grep -Fq "Forwarding from" "${log_file}"; then
      rm -f "${log_file}"
      echo "${port_forward_pid}"
      return 0
    fi
    sleep 1
  done

  cat "${log_file}" >&2 || true
  rm -f "${log_file}"
  stop_pid "${port_forward_pid}"
  die "port-forward did not become ready for ${namespace}/${service}"
}

base64_decode_value() {
  local value="$1"
  if printf '%s' "${value}" | base64 --decode >/dev/null 2>&1; then
    printf '%s' "${value}" | base64 --decode
  else
    printf '%s' "${value}" | base64 -D
  fi
}

json_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  printf '%s' "${value}"
}

extract_json_token() {
  sed -n 's/.*"token"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p'
}

fetch_argocd_initial_admin_password() {
  local kubeconfig_path="$1"
  local encoded
  require_command base64
  encoded="$(kubectl_for "${kubeconfig_path}" -n argocd get secret argocd-initial-admin-secret -o jsonpath='{.data.password}')"
  [[ -n "${encoded}" ]] || die "argocd initial admin password was not found"
  base64_decode_value "${encoded}"
}

fetch_argocd_session_token() {
  local password="$1"
  local local_port="$2"
  local response token password_json

  require_command curl
  password_json="$(json_escape "${password}")"
  response="$(
    printf '{"username":"admin","password":"%s"}' "${password_json}" |
      curl -fksSL --connect-timeout 10 --max-time 60 \
        -H 'Content-Type: application/json' \
        --data-binary @- \
        "http://127.0.0.1:${local_port}/api/v1/session"
  )"
  token="$(printf '%s' "${response}" | extract_json_token)"
  [[ -n "${token}" ]] || die "failed to obtain Argo CD session token"
  printf '%s' "${token}"
}

install_component_commands() {
  local kubeconfig_path="$1"
  local gateway_api_url="$2"
  local argocd_url="$3"
  local rollouts_url="$4"
  local cilium_version="$5"
  local k8s_service_host="$6"
  local tunnel_pid="${7:-}"

  info "Waiting for Kubernetes API"
  wait_for_kube_api "${kubeconfig_path}" "${tunnel_pid}"

  local gateway_api_manifest argocd_manifest rollouts_manifest
  cached_manifest_asset "${gateway_api_url}" "Gateway API manifest" gateway_api_manifest
  cached_manifest_asset "${argocd_url}" "Argo CD manifest" argocd_manifest
  cached_manifest_asset "${rollouts_url}" "Argo Rollouts manifest" rollouts_manifest
  local effective_cilium_version cilium_chart
  effective_cilium_version="${cilium_version:-${DEFAULT_CILIUM_VERSION}}"
  cilium_chart="$(cilium_chart_path "${effective_cilium_version}")"
  require_cached_file "${cilium_chart}" "Cilium chart"
  info "Using cached Cilium chart: ${cilium_chart}"

  info "Installing Gateway API CRDs"
  allow_gateway_api_experimental_upgrade "${kubeconfig_path}" "${gateway_api_manifest}"
  kubectl_apply_retry "${kubeconfig_path}" --server-side --force-conflicts -f "${gateway_api_manifest}"
  info "Waiting for Gateway API CRDs"
  wait_for_crds_established "${kubeconfig_path}" \
    gatewayclasses.gateway.networking.k8s.io \
    gateways.gateway.networking.k8s.io \
    httproutes.gateway.networking.k8s.io \
    grpcroutes.gateway.networking.k8s.io \
    referencegrants.gateway.networking.k8s.io \
    tlsroutes.gateway.networking.k8s.io

  info "Installing Cilium"

  local cilium_args=(
    --kubeconfig "${kubeconfig_path}"
    upgrade --install cilium "${cilium_chart}"
    --timeout 10m
    --disable-openapi-validation
    --namespace kube-system
    --set kubeProxyReplacement=true
    --set routingMode=tunnel
    --set tunnelProtocol=vxlan
    --set gatewayAPI.enabled=true
    --set gatewayAPI.hostNetwork.enabled=true
    --set l7Proxy=true
    --set operator.replicas=1
    --set "k8sServiceHost=${k8s_service_host}"
    --set k8sServicePort=6443
  )
  retry_command 3 10 "${HELM_BIN}" "${cilium_args[@]}"
  wait_for_daemonset_ready "${kubeconfig_path}" kube-system cilium 600

  info "Installing Argo CD"
  create_namespace_if_missing "${kubeconfig_path}" argocd
  kubectl_apply_retry "${kubeconfig_path}" --server-side --force-conflicts -n argocd -f "${argocd_manifest}"
  wait_for_deployment_ready "${kubeconfig_path}" argocd argocd-server 600
  wait_for_deployment_ready "${kubeconfig_path}" argocd argocd-repo-server 600

  info "Installing Argo Rollouts"
  create_namespace_if_missing "${kubeconfig_path}" argo-rollouts
  kubectl_apply_retry "${kubeconfig_path}" --server-side --force-conflicts -n argo-rollouts -f "${rollouts_manifest}"
  wait_for_deployment_ready "${kubeconfig_path}" argo-rollouts argo-rollouts 600
}

apply_cluster_dns_upstreams() {
  local kubeconfig_path="$1"
  shift
  local nodehosts_content="$1"
  shift
  local upstreams=("$@")

  emit_coredns_config_yaml "${nodehosts_content}" "${upstreams[@]}" | apply_delivery_yaml "${kubeconfig_path}"
  kubectl_retry "${kubeconfig_path}" -n kube-system rollout restart deployment/coredns
  wait_for_deployment_ready "${kubeconfig_path}" kube-system coredns 300
}

current_coredns_nodehosts() {
  local kubeconfig_path="$1"
  kubectl_for "${kubeconfig_path}" -n kube-system get configmap coredns -o jsonpath='{.data.NodeHosts}' 2>/dev/null || true
}

repo_server_gitops_probe_command() {
  cat <<'SH'
timeout 20 git ls-remote https://github.com/argoproj/argo-cd.git HEAD >/dev/null
SH
}

append_nodehosts_entry() {
  local current="$1"
  local entry="$2"
  if [[ -z "${entry}" ]]; then
    printf '%s' "${current}"
    return 0
  fi

  if printf '%s\n' "${current}" | grep -Fqx "${entry}"; then
    printf '%s' "${current}"
    return 0
  fi

  if [[ -n "${current}" ]]; then
    printf '%s\n%s' "${current}" "${entry}"
  else
    printf '%s' "${entry}"
  fi
}

validate_gitops_dns() {
  local kubeconfig_path="$1"
  shift
  local upstreams=("$@")
  local nodehosts_content github_ip ghcr_ip probe_command
  probe_command="$(repo_server_gitops_probe_command)"

  if kubectl_retry "${kubeconfig_path}" -n argocd exec deploy/argocd-repo-server -- sh -ec "${probe_command}"; then
    info "GitOps DNS validation passed"
    return 0
  fi

  info "GitOps DNS validation failed"
  if [[ "${#upstreams[@]}" -eq 0 ]]; then
    die "cluster pods cannot resolve GitHub endpoints; rerun deploy with --dns-upstream or fix cluster DNS"
  fi

  info "Applying CoreDNS upstream override: ${upstreams[*]}"
  nodehosts_content="$(current_coredns_nodehosts "${kubeconfig_path}")"
  apply_cluster_dns_upstreams "${kubeconfig_path}" "${nodehosts_content}" "${upstreams[@]}"

  if kubectl_retry "${kubeconfig_path}" -n argocd exec deploy/argocd-repo-server -- sh -ec "${probe_command}"; then
    info "GitOps DNS validation passed after CoreDNS override"
    return 0
  fi

  github_ip="$(resolve_ipv4_address github.com || true)"
  ghcr_ip="$(resolve_ipv4_address ghcr.io || true)"
  [[ -n "${github_ip}" ]] || die "cluster pods still cannot resolve github.com and the server could not resolve it for a host alias fallback"
  [[ -n "${ghcr_ip}" ]] || die "cluster pods still cannot resolve ghcr.io and the server could not resolve it for a host alias fallback"

  info "Applying CoreDNS host aliases for github.com and ghcr.io"
  nodehosts_content="$(append_nodehosts_entry "${nodehosts_content}" "${github_ip} github.com")"
  nodehosts_content="$(append_nodehosts_entry "${nodehosts_content}" "${ghcr_ip} ghcr.io")"
  apply_cluster_dns_upstreams "${kubeconfig_path}" "${nodehosts_content}" "${upstreams[@]}"

  kubectl_retry "${kubeconfig_path}" -n argocd exec deploy/argocd-repo-server -- sh -ec "${probe_command}"
  info "GitOps DNS validation passed after CoreDNS host alias fallback"
}

install_base_components() {
  local ssh_target="$1"
  local api_port="$2"
  local kubeconfig_path="$3"
  local gateway_api_url="$4"
  local argocd_url="$5"
  local rollouts_url="$6"
  local cilium_version="$7"
  local k8s_service_host="$8"

  require_command ssh
  require_command kubectl
  ensure_helm

  info "Starting temporary Kubernetes API tunnel"
  local tunnel_pid
  tunnel_pid="$(start_api_tunnel "${ssh_target}" "${api_port}")"

  local status=0
  set +e
  (
    set -e
    install_component_commands "${kubeconfig_path}" "${gateway_api_url}" "${argocd_url}" "${rollouts_url}" "${cilium_version}" "${k8s_service_host}" "${tunnel_pid}"
  )
  status="$?"
  set -e

  stop_pid "${tunnel_pid}"

  return "${status}"
}

apply_delivery_yaml() {
  local kubeconfig_path="$1"
  local manifest status
  manifest="$(mktemp)"
  cat > "${manifest}"
  status=0
  kubectl_apply_retry "${kubeconfig_path}" -f "${manifest}" || status="$?"
  rm -f "${manifest}"
  return "${status}"
}

default_onecd_image_tag() {
  local onecd_dir="$1"
  local short
  short="$(git -C "${onecd_dir}" rev-parse --short=7 HEAD 2>/dev/null || true)"
  if [[ -n "${short}" ]]; then
    echo "local-${short}-$(date +%Y%m%d%H%M%S)"
  else
    echo "local-$(date +%Y%m%d%H%M%S)"
  fi
}

git_remote_repo_slug() {
  local repo_dir="$1"
  local url path
  url="$(git -C "${repo_dir}" config --get remote.origin.url)"
  case "${url}" in
    git@github.com:*)
      path="${url#git@github.com:}"
      ;;
    https://github.com/*)
      path="${url#https://github.com/}"
      ;;
    *)
      die "unsupported origin url for release console repo: ${url}"
      ;;
  esac
  path="${path%.git}"
  printf '%s\n' "${path}"
}

require_clean_git_worktree() {
  local repo_dir="$1"
  git -C "${repo_dir}" diff --quiet || die "release console repo has uncommitted changes"
  git -C "${repo_dir}" diff --cached --quiet || die "release console repo has uncommitted changes"
  [[ -z "$(git -C "${repo_dir}" ls-files --others --exclude-standard)" ]] || die "release console repo has uncommitted changes"
}

require_release_ref_synced() {
  local repo_dir="$1"
  local ref="$2"
  local local_head remote_head
  git -C "${repo_dir}" fetch origin "${ref}" --quiet
  local_head="$(git -C "${repo_dir}" rev-parse HEAD)"
  remote_head="$(git -C "${repo_dir}" rev-parse FETCH_HEAD)"
  [[ "${local_head}" == "${remote_head}" ]] || die "release console repo HEAD does not match origin/${ref}; push or pull first"
}

gh_cmd() {
  if [[ -n "${KADM_GITHUB_TOKEN:-}" ]]; then
    GH_TOKEN="${KADM_GITHUB_TOKEN}" gh "$@"
    return
  fi
  gh "$@"
}

list_workflow_run_ids() {
  local repo_slug="$1"
  local workflow="$2"
  local ref="$3"
  gh_cmd run list \
    --repo "${repo_slug}" \
    --workflow "${workflow}" \
    --branch "${ref}" \
    --event workflow_dispatch \
    --json databaseId \
    --jq '.[].databaseId'
}

wait_for_new_workflow_run_id() {
  local repo_slug="$1"
  local workflow="$2"
  local ref="$3"
  local before_file="$4"
  local attempt run_id

  for ((attempt = 1; attempt <= 40; attempt++)); do
    run_id="$(
      list_workflow_run_ids "${repo_slug}" "${workflow}" "${ref}" 2>/dev/null |
        grep -E '^[0-9]+$' |
        grep -Fvx -f "${before_file}" |
        head -n 1 || true
    )"
    if [[ -n "${run_id}" ]]; then
      printf '%s\n' "${run_id}"
      return 0
    fi
    sleep 3
  done

  die "timed out waiting for GitHub Actions workflow run to appear"
}

update_overlay_image_tag() {
  local overlay_file="$1"
  local tag="$2"
  local tmp
  tmp="$(mktemp)"

  if ! awk -v tag="${tag}" '
    /^  newTag:/ && !updated {
      print "  newTag: " tag
      updated = 1
      next
    }
    { print }
    END {
      if (!updated) {
        exit 42
      }
    }
  ' "${overlay_file}" > "${tmp}"; then
    rm -f "${tmp}"
    die "failed to update image tag in ${overlay_file}"
  fi

  cat "${tmp}" > "${overlay_file}"
  rm -f "${tmp}"
}

cmd_publish_release_console() {
  apply_kadm_env_aliases
  local repo_dir="${DEFAULT_ONECD_OVERLAY%/k8s/overlays/prod}"
  local image="ghcr.io/ccq18/kadm-release-console"
  local tag=""
  local ref="main"
  local workflow="build-and-publish.yaml"
  local apply=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo-dir)
        repo_dir="${2:-}"
        shift 2
        ;;
      --onecd-dir)
        repo_dir="${2:-}"
        shift 2
        ;;
      --tag)
        tag="${2:-}"
        shift 2
        ;;
      --ref)
        ref="${2:-}"
        shift 2
        ;;
      --workflow)
        workflow="${2:-}"
        shift 2
        ;;
      --apply)
        apply=1
        shift
        ;;
      --dry-run)
        apply=0
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        die "unknown publish-release-console option: $1"
        ;;
    esac
  done

  [[ -d "${repo_dir}" ]] || die "KADM release console directory not found: ${repo_dir}"
  local overlay_file="${repo_dir}/k8s/overlays/prod/kustomization.yaml"
  [[ -f "${overlay_file}" ]] || die "KADM release console prod overlay not found: ${overlay_file}"

  tag="${tag:-$(default_onecd_image_tag "${repo_dir}")}"
  validate_image_repo "${image}"
  validate_image_tag "${tag}"
  validate_git_ref "${ref}"
  local repo_slug
  repo_slug="$(git_remote_repo_slug "${repo_dir}")"

  if [[ "${apply}" -ne 1 ]]; then
    info "DRY RUN: KADM release console release will not be triggered"
    info "repo dir: ${repo_dir}"
    info "repo: ${repo_slug}"
    info "image: ${image}:${tag}"
    info "workflow: ${workflow}"
    info "ref: ${ref}"
    info "updates overlay: ${overlay_file}"
    return 0
  fi

  require_command git
  require_command gh
  require_clean_git_worktree "${repo_dir}"
  require_release_ref_synced "${repo_dir}" "${ref}"

  local before_file run_id
  before_file="$(mktemp)"
  list_workflow_run_ids "${repo_slug}" "${workflow}" "${ref}" > "${before_file}" || true

  gh_cmd workflow run "${workflow}" --repo "${repo_slug}" --ref "${ref}" -f "image_tag=${tag}" >/dev/null
  run_id="$(wait_for_new_workflow_run_id "${repo_slug}" "${workflow}" "${ref}" "${before_file}")"
  rm -f "${before_file}"
  info "triggered KADM release console workflow run: ${run_id}"
  gh_cmd run watch "${run_id}" --repo "${repo_slug}" --exit-status
  git -C "${repo_dir}" pull --ff-only origin "${ref}"

  info "updated overlay from git: ${overlay_file}"
}

emit_onecd_secret_yaml() {
  local github_token="$1"
  local argocd_token="$2"
  local argocd_base_url="$3"
  local cluster_name="$4"
  local join_server_url="$5"
  local join_token="$6"
  cat <<YAML
apiVersion: v1
kind: Secret
metadata:
  name: kadm-secrets
  namespace: kadm
type: Opaque
stringData:
  GITHUB_TOKEN: |-
    ${github_token}
  ARGOCD_BASE_URL: |-
    ${argocd_base_url}
  ARGOCD_TOKEN: |-
    ${argocd_token}
  KADM_CLUSTER_NAME: |-
    ${cluster_name}
  K3S_JOIN_SERVER_URL: |-
    ${join_server_url}
  K3S_JOIN_TOKEN: |-
    ${join_token}
YAML
}

emit_argocd_repo_secret_yaml() {
  local name="$1"
  local repo_url="$2"
  local github_token="$3"
  cat <<YAML
apiVersion: v1
kind: Secret
metadata:
  name: repo-${name}
  namespace: argocd
  labels:
    argocd.argoproj.io/secret-type: repository
type: Opaque
stringData:
  type: git
  url: ${repo_url}
  username: x-access-token
  password: |-
    ${github_token}
YAML
}

emit_argocd_application_yaml() {
  local name="$1"
  local repo_url="$2"
  local namespace="$3"
  local path="${4:-k8s/overlays/prod}"
  local revision="${5:-main}"
  local manager_label="${6:-}"
  cat <<YAML
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: ${name}
  namespace: argocd
$(if [[ -n "${manager_label}" ]]; then cat <<LABEL
  labels:
    kadm.ai/managed-by: ${manager_label}
LABEL
fi)
spec:
  project: default
  source:
    repoURL: ${repo_url}
    targetRevision: ${revision}
    path: ${path}
  destination:
    server: https://kubernetes.default.svc
    namespace: ${namespace}
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
YAML
}

list_registry_apps() {
  local apps_file="$1"
  python3 - "${apps_file}" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as handle:
    apps = json.load(handle)

for app in apps:
    fields = [
        app["id"],
        app["argocd"]["application"],
        app["gitops"]["owner"],
        app["gitops"]["repo"],
        app["gitops"]["path"],
        app["gitops"].get("ref", "main"),
        app["rollout"]["namespace"],
    ]
    print("\t".join(fields))
PY
}

emit_kadm_apps_config_yaml() {
  local apps_file="$1"
  [[ -f "${apps_file}" ]] || die "app config file not found: ${apps_file}"
  cat <<YAML
apiVersion: v1
kind: ConfigMap
metadata:
  name: kadm-apps-config
  namespace: kadm
data:
  apps.json: |
$(sed 's/^/    /' "${apps_file}")
YAML
}

emit_ghcr_pull_secret_yaml() {
  local username="$1"
  local token="$2"
  local namespace="${3:-kadm}"
  local dockerconfig
  dockerconfig="$(printf '{"auths":{"ghcr.io":{"username":"%s","password":"%s","auth":"%s"}}}' "${username}" "${token}" "$(printf '%s:%s' "${username}" "${token}" | base64 | tr -d '\n')")"
  cat <<YAML
apiVersion: v1
kind: Secret
metadata:
  name: ghcr-cred
  namespace: ${namespace}
type: kubernetes.io/dockerconfigjson
data:
  .dockerconfigjson: $(printf '%s' "${dockerconfig}" | base64 | tr -d '\n')
YAML
}

emit_coredns_config_yaml() {
  local nodehosts_content="${1:-}"
  shift
  local upstreams=("$@")
  [[ "${#upstreams[@]}" -gt 0 ]] || die "at least one DNS upstream is required"
  cat <<YAML
apiVersion: v1
kind: ConfigMap
metadata:
  name: coredns
  namespace: kube-system
data:
  Corefile: |
    .:53 {
        errors
        health
        ready
        kubernetes cluster.local in-addr.arpa ip6.arpa {
          pods insecure
          fallthrough in-addr.arpa ip6.arpa
        }
        hosts /etc/coredns/NodeHosts {
          ttl 60
          reload 15s
          fallthrough
        }
        prometheus :9153
        cache 30
        loop
        reload
        loadbalance
        import /etc/coredns/custom/*.override
        forward . ${upstreams[*]}
    }
    import /etc/coredns/custom/*.server
  NodeHosts: |
$(printf '%s\n' "${nodehosts_content}" | sed 's/^/    /')
YAML
}

extract_yaml_string_field() {
  local file="$1"
  local key="$2"
  awk -F': ' -v key="${key}" '$1 == key { print $2; exit }' "${file}"
}

extract_rollout_env_value() {
  local file="$1"
  local key="$2"
  awk -v key="${key}" '
    $1 == "-" && $2 == "name:" && $3 == key { found = 1; next }
    found && $1 == "value:" {
      gsub(/"/, "", $2)
      print $2
      exit
    }
  ' "${file}"
}

wait_for_labeled_pods_ready() {
  local kubeconfig_path="$1"
  local namespace="$2"
  local selector="$3"
  local timeout_seconds="$4"
  local deadline=$((SECONDS + timeout_seconds))
  local state

  while (( SECONDS < deadline )); do
    state="$(kubectl_for "${kubeconfig_path}" -n "${namespace}" get pods -l "${selector}" -o jsonpath='{range .items[*]}{.status.containerStatuses[0].ready} {.status.phase}{"\n"}{end}' 2>/dev/null || true)"
    if [[ -n "${state}" ]] && printf '%s\n' "${state}" | awk 'NF > 0 && ($1 != "true" || $2 != "Running") { exit 1 } END { exit 0 }'; then
      info "pods ready for selector ${selector}"
      return 0
    fi
    info "waiting for pods with selector ${selector}"
    sleep 5
  done

  die "timed out waiting for pods with selector ${selector}"
}

configure_mysql_demo_app() {
  local ssh_target="$1"
  local secret_file="$2"
  local user password db_name
  user="$(extract_yaml_string_field "${secret_file}" "  DB_USER")"
  password="$(extract_yaml_string_field "${secret_file}" "  DB_PASSWORD")"
  db_name="$(extract_yaml_string_field "${secret_file}" "  DB_NAME")"
  [[ -n "${user}" && -n "${password}" && -n "${db_name}" ]] || die "failed to parse database secret file: ${secret_file}"

  ssh "${ssh_target}" sudo sh -s <<REMOTE
set -eu
mysql -uroot <<'SQL'
CREATE DATABASE IF NOT EXISTS ${db_name}
  CHARACTER SET utf8mb4
  COLLATE utf8mb4_unicode_ci;
CREATE USER IF NOT EXISTS '${user}'@'localhost' IDENTIFIED BY '${password}';
CREATE USER IF NOT EXISTS '${user}'@'127.0.0.1' IDENTIFIED BY '${password}';
CREATE USER IF NOT EXISTS '${user}'@'10.42.%' IDENTIFIED BY '${password}';
CREATE USER IF NOT EXISTS '${user}'@'10.0.%' IDENTIFIED BY '${password}';
CREATE USER IF NOT EXISTS '${user}'@'10.120.0.%' IDENTIFIED BY '${password}';
ALTER USER '${user}'@'localhost' IDENTIFIED BY '${password}';
ALTER USER '${user}'@'127.0.0.1' IDENTIFIED BY '${password}';
ALTER USER '${user}'@'10.42.%' IDENTIFIED BY '${password}';
ALTER USER '${user}'@'10.0.%' IDENTIFIED BY '${password}';
ALTER USER '${user}'@'10.120.0.%' IDENTIFIED BY '${password}';
GRANT ALL PRIVILEGES ON ${db_name}.* TO '${user}'@'localhost';
GRANT ALL PRIVILEGES ON ${db_name}.* TO '${user}'@'127.0.0.1';
GRANT ALL PRIVILEGES ON ${db_name}.* TO '${user}'@'10.42.%';
GRANT ALL PRIVILEGES ON ${db_name}.* TO '${user}'@'10.0.%';
GRANT ALL PRIVILEGES ON ${db_name}.* TO '${user}'@'10.120.0.%';
FLUSH PRIVILEGES;
SQL
REMOTE
}

cmd_deploy() {
  local cluster="${DEFAULT_CLUSTER}"
  local access_host=""
  local private_ip=""
  local api_port="${DEFAULT_API_PORT}"
  local console_port="${DEFAULT_CONSOLE_PORT}"
  local k3s_version="${DEFAULT_K3S_VERSION}"
  local cilium_version=""
  local gateway_api_url="${DEFAULT_GATEWAY_API_URL}"
  local argocd_url="${DEFAULT_ARGOCD_URL}"
  local rollouts_url="${DEFAULT_ROLLOUTS_URL}"
  local skip_components=0
  local apply=0
  local dns_upstreams=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)
        cluster="${2:-}"
        shift 2
        ;;
      --access-host)
        access_host="${2:-}"
        shift 2
        ;;
      --private-ip)
        private_ip="${2:-}"
        shift 2
        ;;
      --api-port)
        api_port="${2:-}"
        shift 2
        ;;
      --console-port)
        console_port="${2:-}"
        shift 2
        ;;
      --k3s-version)
        k3s_version="${2:-}"
        shift 2
        ;;
      --cilium-version)
        cilium_version="${2:-}"
        shift 2
        ;;
      --gateway-api-url)
        gateway_api_url="${2:-}"
        shift 2
        ;;
      --argocd-url)
        argocd_url="${2:-}"
        shift 2
        ;;
      --rollouts-url)
        rollouts_url="${2:-}"
        shift 2
        ;;
      --dns-upstream)
        dns_upstreams+=("${2:-}")
        shift 2
        ;;
      --skip-components)
        skip_components=1
        shift
        ;;
      --apply)
        apply=1
        shift
        ;;
      --dry-run)
        apply=0
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      --*)
        die "unknown deploy option: $1"
        ;;
      *)
        die "unexpected deploy argument: $1"
        ;;
    esac
  done

  validate_cluster_name "${cluster}"
  [[ -n "${access_host}" ]] || die "deploy requires --access-host <ssh-target> so client setup knows how to reach the primary node"
  validate_ssh_target "${access_host}"
  validate_optional_machine_value "private ip" "${private_ip}"
  validate_optional_machine_value "k3s version" "${k3s_version}"
  validate_optional_machine_value "cilium version" "${cilium_version}"
  validate_port "${api_port}"
  validate_port "${console_port}"

  if [[ -z "${private_ip}" ]]; then
    private_ip="$(detect_local_private_ip || true)"
  fi
  [[ -n "${private_ip}" ]] || die "deploy requires --private-ip or a detectable default IPv4 address"

  local kubeconfig_path
  kubeconfig_path="$(kubeconfig_path_for "${cluster}")"

  if [[ "${apply}" -ne 1 ]]; then
    info "DRY RUN: no local changes will be made"
    info "cluster: ${cluster}"
    info "access host: ${access_host}"
    info "private ip: ${private_ip}"
    info "install: local K3s Server + embedded etcd"
    if [[ "${skip_components}" -eq 1 ]]; then
      info "components: skipped"
      info "gitops dns validation: skipped"
    else
      info "components: Gateway API, Cilium, Argo CD, Argo Rollouts"
      info "gitops dns validation: enabled"
    fi
    info "local kubeconfig: ${kubeconfig_path}"
    info "cluster profile: $(profile_path "${cluster}")"
    info "next: kadmctl configure-delivery ${cluster} --apply"
    return 0
  fi

  require_command sudo
  require_command sed
  require_command mktemp

  info "Installing first local K3s server"
  install_local_k3s "${private_ip}" "${k3s_version}"

  local tmp_kubeconfig
  tmp_kubeconfig="$(mktemp)"

  info "Fetching local kubeconfig"
  fetch_local_kubeconfig "${tmp_kubeconfig}"
  copy_local_kubeconfig "${tmp_kubeconfig}" "${kubeconfig_path}"
  rm -f "${tmp_kubeconfig}"
  local join_token join_server_url
  join_token="$(fetch_local_join_token)"
  join_server_url="https://${private_ip}:6443"
  write_profile "${cluster}" "${access_host}" "${private_ip}" "${kubeconfig_path}" "${api_port}" "${console_port}" "${join_server_url}" "${join_token}"

  if [[ "${skip_components}" -ne 1 ]]; then
    require_command kubectl
    ensure_helm
    install_component_commands "${kubeconfig_path}" "${gateway_api_url}" "${argocd_url}" "${rollouts_url}" "${cilium_version}" "${private_ip}"
    if [[ "${#dns_upstreams[@]}" -gt 0 ]]; then
      validate_gitops_dns "${kubeconfig_path}" "${dns_upstreams[@]}"
    else
      validate_gitops_dns "${kubeconfig_path}"
    fi
  else
    info "Skipping base component installation"
  fi

  info "cluster profile written: $(profile_path "${cluster}")"
  info "local kubeconfig written: ${kubeconfig_path}"
  info "next: kadmctl configure-delivery ${cluster} --apply"
}

cmd_bootstrap() {
  local ssh_target=""
  local cluster="${DEFAULT_CLUSTER}"
  local private_ip=""
  local api_port="${DEFAULT_API_PORT}"
  local console_port="${DEFAULT_CONSOLE_PORT}"
  local k3s_version="${DEFAULT_K3S_VERSION}"
  local cilium_version=""
  local gateway_api_url="${DEFAULT_GATEWAY_API_URL}"
  local argocd_url="${DEFAULT_ARGOCD_URL}"
  local rollouts_url="${DEFAULT_ROLLOUTS_URL}"
  local skip_components=0
  local apply=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)
        cluster="${2:-}"
        shift 2
        ;;
      --private-ip)
        private_ip="${2:-}"
        shift 2
        ;;
      --api-port)
        api_port="${2:-}"
        shift 2
        ;;
      --console-port)
        console_port="${2:-}"
        shift 2
        ;;
      --k3s-version)
        k3s_version="${2:-}"
        shift 2
        ;;
      --cilium-version)
        cilium_version="${2:-}"
        shift 2
        ;;
      --gateway-api-url)
        gateway_api_url="${2:-}"
        shift 2
        ;;
      --argocd-url)
        argocd_url="${2:-}"
        shift 2
        ;;
      --rollouts-url)
        rollouts_url="${2:-}"
        shift 2
        ;;
      --skip-components)
        skip_components=1
        shift
        ;;
      --apply)
        apply=1
        shift
        ;;
      --dry-run)
        apply=0
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      --*)
        die "unknown bootstrap option: $1"
        ;;
      *)
        if [[ -n "${ssh_target}" ]]; then
          die "unexpected bootstrap argument: $1"
        fi
        ssh_target="$1"
        shift
        ;;
    esac
  done

  [[ -n "${ssh_target}" ]] || die "bootstrap requires an ssh target, for example root@1.2.3.4"
  validate_cluster_name "${cluster}"
  validate_ssh_target "${ssh_target}"
  validate_optional_machine_value "private ip" "${private_ip}"
  validate_optional_machine_value "k3s version" "${k3s_version}"
  validate_optional_machine_value "cilium version" "${cilium_version}"
  validate_port "${api_port}"
  validate_port "${console_port}"

  local kubeconfig_path
  kubeconfig_path="$(kubeconfig_path_for "${cluster}")"

  if [[ "${apply}" -ne 1 ]]; then
    info "DRY RUN: no remote changes will be made"
    info "cluster: ${cluster}"
    info "first master: ${ssh_target}"
    info "private ip: ${private_ip:-not provided}"
    info "install: K3s Server + embedded etcd"
    info "network: flannel disabled, kube-proxy disabled, Traefik/ServiceLB disabled"
    if [[ "${skip_components}" -eq 1 ]]; then
      info "components: skipped"
    else
      info "components: Gateway API, Cilium, Argo CD, Argo Rollouts"
      info "delivery credentials: not required for base components"
    fi
    info "local api tunnel: https://127.0.0.1:${api_port}"
    info "local kubeconfig: ${kubeconfig_path}"
    info "cluster profile: $(profile_path "${cluster}")"
    info "next: kadmctl connect ${cluster}"
    return 0
  fi

  require_command ssh
  require_command sed
  require_command mktemp

  info "Installing first K3s server on ${ssh_target}"
  bootstrap_remote_k3s "${ssh_target}" "${private_ip}" "${k3s_version}"

  local tmp_kubeconfig
  tmp_kubeconfig="$(mktemp)"

  info "Fetching kubeconfig from ${ssh_target}"
  fetch_remote_kubeconfig "${ssh_target}" "${tmp_kubeconfig}"
  rewrite_kubeconfig_for_tunnel "${tmp_kubeconfig}" "${kubeconfig_path}" "${api_port}"
  rm -f "${tmp_kubeconfig}"
  local join_token join_host join_server_url
  join_token="$(fetch_remote_join_token "${ssh_target}")"
  join_host="${private_ip:-$(ssh_host_part "${ssh_target}")}"
  join_server_url="https://${join_host}:6443"
  write_profile "${cluster}" "${ssh_target}" "${private_ip}" "${kubeconfig_path}" "${api_port}" "${console_port}" "${join_server_url}" "${join_token}"

  if [[ "${skip_components}" -ne 1 ]]; then
    install_base_components "${ssh_target}" "${api_port}" "${kubeconfig_path}" "${gateway_api_url}" "${argocd_url}" "${rollouts_url}" "${cilium_version}" "${join_host}"
  else
    info "Skipping base component installation"
  fi

  info "cluster profile written: $(profile_path "${cluster}")"
  info "local kubeconfig written: ${kubeconfig_path}"
    info "connect with: kadmctl connect ${cluster}"
}

cmd_configure_delivery() {
  apply_kadm_env_aliases
  local cluster="${DEFAULT_CLUSTER}"
  local onecd_overlay="${DEFAULT_ONECD_OVERLAY}"
  local app_configs_dir="${DEFAULT_APP_CONFIGS_DIR}"
  local argocd_base_url="https://argocd-server.argocd.svc.cluster.local"
  local argocd_local_port="${DEFAULT_ARGOCD_LOCAL_PORT}"
  local apply=0
  local cluster_seen=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --onecd-overlay)
        onecd_overlay="${2:-}"
        shift 2
        ;;
      --app-configs-dir)
        app_configs_dir="${2:-}"
        shift 2
        ;;
      --argocd-base-url)
        argocd_base_url="${2:-}"
        shift 2
        ;;
      --argocd-local-port)
        argocd_local_port="${2:-}"
        shift 2
        ;;
      --apply)
        apply=1
        shift
        ;;
      --dry-run)
        apply=0
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      --*)
        die "unknown configure-delivery option: $1"
        ;;
      *)
        if [[ "${cluster_seen}" -eq 1 ]]; then
          die "unexpected configure-delivery argument: $1"
        fi
        cluster="$1"
        cluster_seen=1
        shift
        ;;
    esac
  done

  validate_cluster_name "${cluster}"
  validate_port "${argocd_local_port}"
  load_profile "${cluster}"

  if [[ "${apply}" -ne 1 ]]; then
    info "DRY RUN: delivery credentials will not be written"
    info "cluster: ${CLUSTER_NAME}"
    info "requires env: KADM_GITHUB_TOKEN"
    info "optional env: KADM_ARGOCD_TOKEN; generated from Argo CD admin session when unset"
    info "optional env: KADM_GHCR_USERNAME and KADM_GHCR_TOKEN"
    info "creates: kadm/kadm-secrets"
    info "creates: kadm/kadm-apps-config"
    info "creates: argocd repository credentials"
    info "creates: kadm/ghcr-cred when GHCR env vars are set"
    info "deploys: KADM release console kustomize overlay at ${onecd_overlay}"
    info "apps repo: ${app_configs_dir}"
    info "temporary Argo CD port-forward: http://127.0.0.1:${argocd_local_port}"
    return 0
  fi

  require_command kubectl
  require_command python3
  require_env ONECD_GITHUB_TOKEN
  [[ -f "${KUBECONFIG_PATH}" ]] || die "kubeconfig not found: ${KUBECONFIG_PATH}"
  [[ -d "${onecd_overlay}" ]] || die "KADM release console overlay directory not found: ${onecd_overlay}"
  [[ -d "${app_configs_dir}" ]] || die "KADM app configs directory not found: ${app_configs_dir}"
  [[ -f "${app_configs_dir}/apps/apps.json" ]] || die "KADM app configs file not found: ${app_configs_dir}/apps/apps.json"

  if [[ -n "${ONECD_GHCR_USERNAME:-}" || -n "${ONECD_GHCR_TOKEN:-}" ]]; then
    require_env ONECD_GHCR_USERNAME
    require_env ONECD_GHCR_TOKEN
  fi

  local tunnel_pid
  if is_local_ssh_target "${MASTER_SSH}" || is_local_address "${MASTER_PRIVATE_IP:-}"; then
    info "Using local Kubernetes API access for delivery configuration"
    tunnel_pid=""
  else
    require_command ssh
    info "Starting temporary Kubernetes API tunnel for delivery configuration"
    tunnel_pid="$(start_api_tunnel "${MASTER_SSH}" "${API_LOCAL_PORT}")"
  fi
  wait_for_kube_api "${KUBECONFIG_PATH}" "${tunnel_pid}"

  local argocd_token="${ONECD_ARGOCD_TOKEN:-}"
  if [[ -z "${argocd_token}" ]]; then
    info "Generating Argo CD session token for KADM release console"
    local argocd_password argocd_port_forward_pid token_status
    argocd_password=""
    argocd_port_forward_pid=""
    token_status=0

    set +e
    argocd_password="$(fetch_argocd_initial_admin_password "${KUBECONFIG_PATH}")"
    token_status="$?"
    if [[ "${token_status}" -eq 0 ]]; then
      argocd_port_forward_pid="$(start_service_port_forward "${KUBECONFIG_PATH}" argocd argocd-server "${argocd_local_port}" 80)"
      token_status="$?"
    fi
    if [[ "${token_status}" -eq 0 ]]; then
      argocd_token="$(fetch_argocd_session_token "${argocd_password}" "${argocd_local_port}")"
      token_status="$?"
    fi
    set -e

    stop_pid "${argocd_port_forward_pid}"
    [[ "${token_status}" -eq 0 ]] || {
      stop_pid "${tunnel_pid}"
      return "${token_status}"
    }
  fi

  local status=0
  set +e
  (
    set -e
    local desired_apps_file registry_name app_name gitops_owner gitops_repo gitops_path gitops_ref rollout_namespace existing_app
    desired_apps_file="$(mktemp)"
    create_namespace_if_missing "${KUBECONFIG_PATH}" kadm
    create_namespace_if_missing "${KUBECONFIG_PATH}" argocd
    create_namespace_if_missing "${KUBECONFIG_PATH}" apps

    emit_onecd_secret_yaml "${ONECD_GITHUB_TOKEN}" "${argocd_token}" "${argocd_base_url}" "${CLUSTER_NAME}" "${K3S_JOIN_SERVER_URL:-}" "${K3S_JOIN_TOKEN:-}" | apply_delivery_yaml "${KUBECONFIG_PATH}"
    emit_kadm_apps_config_yaml "${app_configs_dir}/apps/apps.json" | apply_delivery_yaml "${KUBECONFIG_PATH}"
    emit_argocd_repo_secret_yaml kadm-release-console "https://github.com/ccq18/kadm-release-console.git" "${ONECD_GITHUB_TOKEN}" | apply_delivery_yaml "${KUBECONFIG_PATH}"
    emit_argocd_repo_secret_yaml kadm-app-configs "https://github.com/ccq18/kadm-app-configs.git" "${ONECD_GITHUB_TOKEN}" | apply_delivery_yaml "${KUBECONFIG_PATH}"
    emit_argocd_application_yaml kadm-release-console "https://github.com/ccq18/kadm-release-console.git" kadm "k8s/overlays/prod" "main" "system" | apply_delivery_yaml "${KUBECONFIG_PATH}"
    while IFS=$'\t' read -r registry_name app_name gitops_owner gitops_repo gitops_path gitops_ref rollout_namespace; do
      [[ -n "${app_name}" ]] || continue
      printf '%s\n' "${app_name}" >> "${desired_apps_file}"
      emit_argocd_application_yaml "${app_name}" "https://github.com/${gitops_owner}/${gitops_repo}.git" "${rollout_namespace}" "${gitops_path}" "${gitops_ref}" "apps-registry" | apply_delivery_yaml "${KUBECONFIG_PATH}"
    done < <(list_registry_apps "${app_configs_dir}/apps/apps.json")
    while IFS= read -r existing_app; do
      [[ -n "${existing_app}" ]] || continue
      if ! grep -Fqx "${existing_app}" "${desired_apps_file}"; then
        kubectl_retry "${KUBECONFIG_PATH}" -n argocd delete application "${existing_app}" --ignore-not-found
      fi
    done < <(kubectl_for "${KUBECONFIG_PATH}" -n argocd get applications -l kadm.ai/managed-by=apps-registry -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{end}')
    rm -f "${desired_apps_file}"
    if [[ -n "${ONECD_GHCR_USERNAME:-}" ]]; then
      emit_ghcr_pull_secret_yaml "${ONECD_GHCR_USERNAME}" "${ONECD_GHCR_TOKEN}" kadm | apply_delivery_yaml "${KUBECONFIG_PATH}"
      emit_ghcr_pull_secret_yaml "${ONECD_GHCR_USERNAME}" "${ONECD_GHCR_TOKEN}" apps | apply_delivery_yaml "${KUBECONFIG_PATH}"
    fi
    kubectl_apply_retry "${KUBECONFIG_PATH}" -k "${onecd_overlay}"
    kubectl_retry "${KUBECONFIG_PATH}" -n kadm rollout restart deployment/kadm
    wait_for_deployment_ready "${KUBECONFIG_PATH}" kadm kadm 300
  )
  status="$?"
  set -e

  stop_pid "${tunnel_pid}"
  [[ "${status}" -eq 0 ]] || return "${status}"

  info "delivery configuration applied"
  info "next: kadmctl connect ${CLUSTER_NAME}"
}

cmd_connect() {
  local cluster="${DEFAULT_CLUSTER}"
  local api_port_override=""
  local console_port_override=""
  local dry_run=0
  local cluster_seen=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --api-port)
        api_port_override="${2:-}"
        shift 2
        ;;
      --console-port)
        console_port_override="${2:-}"
        shift 2
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      --*)
        die "unknown connect option: $1"
        ;;
      *)
        if [[ "${cluster_seen}" -eq 1 ]]; then
          die "unexpected connect argument: $1"
        fi
        cluster="$1"
        cluster_seen=1
        shift
        ;;
    esac
  done

  validate_cluster_name "${cluster}"
  load_profile "${cluster}"

  local api_port="${api_port_override:-${API_LOCAL_PORT}}"
  local console_port="${console_port_override:-${CONSOLE_LOCAL_PORT}}"
  validate_port "${api_port}"
  validate_port "${console_port}"

  if [[ "${dry_run}" -eq 1 ]]; then
    info "DRY RUN: no tunnel or port-forward will be started"
    info "cluster: ${CLUSTER_NAME}"
    info "ssh -N -L ${api_port}:127.0.0.1:6443 ${MASTER_SSH}"
    info "kubectl --kubeconfig ${KUBECONFIG_PATH} -n kadm port-forward svc/kadm ${console_port}:80"
    info "KADM Console: http://127.0.0.1:${console_port}"
    return 0
  fi

  require_command ssh
  require_command kubectl

  [[ -f "${KUBECONFIG_PATH}" ]] || die "kubeconfig not found: ${KUBECONFIG_PATH}"

  local ssh_pid=""
  local port_forward_pid=""
  local port_forward_log=""
  cleanup() {
    stop_pid "${port_forward_pid:-}"
    stop_pid "${ssh_pid:-}"
    rm -f "${port_forward_log:-}"
  }
  trap cleanup EXIT INT TERM

  info "Starting SSH tunnel for cluster ${CLUSTER_NAME}"
  ssh -N -L "${api_port}:127.0.0.1:6443" -o ExitOnForwardFailure=yes "${MASTER_SSH}" >/dev/null 2>&1 &
  ssh_pid="$!"
  sleep 1
  if ! kill -0 "${ssh_pid}" >/dev/null 2>&1; then
    die "SSH tunnel failed to start"
  fi
  wait_for_kube_api "${KUBECONFIG_PATH}" "${ssh_pid}"

  info "Starting KADM port-forward"
  port_forward_log="$(mktemp)"
  kubectl_for "${KUBECONFIG_PATH}" -n kadm port-forward svc/kadm "${console_port}:80" >"${port_forward_log}" 2>&1 &
  port_forward_pid="$!"

  local i
  for ((i = 1; i <= 30; i++)); do
    if ! kill -0 "${port_forward_pid}" >/dev/null 2>&1; then
      cat "${port_forward_log}" >&2 || true
      die "KADM port-forward failed to start"
    fi
    if grep -Fq "Forwarding from" "${port_forward_log}"; then
      break
    fi
    sleep 1
  done
  if ! grep -Fq "Forwarding from" "${port_forward_log}"; then
    cat "${port_forward_log}" >&2 || true
    die "KADM port-forward did not become ready"
  fi

  info "Connected to cluster: ${CLUSTER_NAME}"
  info "Kubernetes API: https://127.0.0.1:${api_port}"
  info "KADM Console: http://127.0.0.1:${console_port}"
  info "Press Ctrl-C to disconnect."

  wait "${port_forward_pid}"
}

run_status_command() {
  local label="$1"
  shift
  info ""
  info "== ${label} =="
  if "$@"; then
    return 0
  fi
  info "status command failed: ${label}"
  return 1
}

cmd_status() {
  local cluster="${DEFAULT_CLUSTER}"
  local api_port_override=""
  local cluster_seen=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --api-port)
        api_port_override="${2:-}"
        shift 2
        ;;
      -h|--help)
        usage
        return 0
        ;;
      --*)
        die "unknown status option: $1"
        ;;
      *)
        if [[ "${cluster_seen}" -eq 1 ]]; then
          die "unexpected status argument: $1"
        fi
        cluster="$1"
        cluster_seen=1
        shift
        ;;
    esac
  done

  validate_cluster_name "${cluster}"
  load_profile "${cluster}"

  local api_port="${api_port_override:-${API_LOCAL_PORT}}"
  validate_port "${api_port}"

  require_command kubectl
  [[ -f "${KUBECONFIG_PATH}" ]] || die "kubeconfig not found: ${KUBECONFIG_PATH}"

  info "Cluster status: ${CLUSTER_NAME}"
  local tunnel_pid
  if is_local_ssh_target "${MASTER_SSH}" || is_local_address "${MASTER_PRIVATE_IP:-}"; then
    info "Using local Kubernetes API access"
    tunnel_pid=""
  else
    require_command ssh
    tunnel_pid="$(start_api_tunnel "${MASTER_SSH}" "${api_port}")"
  fi
  wait_for_kube_api "${KUBECONFIG_PATH}" "${tunnel_pid}"

  local status=0
  run_status_command "nodes" kubectl_for "${KUBECONFIG_PATH}" get nodes -o wide || status=1
  run_status_command "pods" kubectl_for "${KUBECONFIG_PATH}" get pods -A -o wide || status=1
  run_status_command "cilium daemonset" kubectl_for "${KUBECONFIG_PATH}" -n kube-system get daemonset cilium -o wide || status=1
  run_status_command "cilium pods" kubectl_for "${KUBECONFIG_PATH}" -n kube-system get pods -l k8s-app=cilium -o wide || status=1
  run_status_command "cilium daemonset details" kubectl_for "${KUBECONFIG_PATH}" -n kube-system describe daemonset cilium || status=1
  run_status_command "cilium logs" kubectl_for "${KUBECONFIG_PATH}" -n kube-system logs -l k8s-app=cilium --all-containers=true --tail=160 || status=1
  run_status_command "cilium operator logs" kubectl_for "${KUBECONFIG_PATH}" -n kube-system logs deployment/cilium-operator --all-containers=true --tail=160 || status=1
  run_status_command "cilium operator previous logs" kubectl_for "${KUBECONFIG_PATH}" -n kube-system logs deployment/cilium-operator --all-containers=true --tail=160 --previous || status=1
  run_status_command "recent events" kubectl_for "${KUBECONFIG_PATH}" get events -A --sort-by=.lastTimestamp || status=1

  stop_pid "${tunnel_pid}"
  return "${status}"
}

cmd_cleanup_legacy_onecd() {
  local cluster="${DEFAULT_CLUSTER}"
  local api_port_override=""
  local apply=0
  local cluster_seen=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --api-port)
        api_port_override="${2:-}"
        shift 2
        ;;
      --apply)
        apply=1
        shift
        ;;
      --dry-run)
        apply=0
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      --*)
        die "unknown cleanup-legacy-onecd option: $1"
        ;;
      *)
        if [[ "${cluster_seen}" -eq 1 ]]; then
          die "unexpected cleanup-legacy-onecd argument: $1"
        fi
        cluster="$1"
        cluster_seen=1
        shift
        ;;
    esac
  done

  validate_cluster_name "${cluster}"
  load_profile "${cluster}"

  local api_port="${api_port_override:-${API_LOCAL_PORT}}"
  validate_port "${api_port}"

  if [[ "${apply}" -ne 1 ]]; then
    info "DRY RUN: no legacy cluster resources will be deleted"
    info "cluster: ${CLUSTER_NAME}"
    info "deletes: argocd application onecd"
    info "deletes: argocd repo secret repo-onecd"
    info "deletes: apps role/rolebinding onecd-rollouts"
    info "deletes: clusterrole/clusterrolebinding onecd-cluster-read"
    info "deletes: namespace onecd"
    return 0
  fi

  require_command kubectl
  [[ -f "${KUBECONFIG_PATH}" ]] || die "kubeconfig not found: ${KUBECONFIG_PATH}"

  local tunnel_pid
  if is_local_ssh_target "${MASTER_SSH}" || is_local_address "${MASTER_PRIVATE_IP:-}"; then
    info "Using local Kubernetes API access"
    tunnel_pid=""
  else
    require_command ssh
    tunnel_pid="$(start_api_tunnel "${MASTER_SSH}" "${api_port}")"
  fi
  wait_for_kube_api "${KUBECONFIG_PATH}" "${tunnel_pid}"

  kubectl_retry "${KUBECONFIG_PATH}" -n argocd delete application onecd --ignore-not-found
  kubectl_retry "${KUBECONFIG_PATH}" -n argocd delete secret repo-onecd --ignore-not-found
  kubectl_retry "${KUBECONFIG_PATH}" -n apps delete rolebinding onecd-rollouts --ignore-not-found
  kubectl_retry "${KUBECONFIG_PATH}" -n apps delete role onecd-rollouts --ignore-not-found
  kubectl_retry "${KUBECONFIG_PATH}" delete clusterrolebinding onecd-cluster-read --ignore-not-found
  kubectl_retry "${KUBECONFIG_PATH}" delete clusterrole onecd-cluster-read --ignore-not-found
  kubectl_retry "${KUBECONFIG_PATH}" delete namespace onecd --ignore-not-found

  stop_pid "${tunnel_pid}"
  info "legacy onecd resources deleted"
}

cmd_configure_demo_apps() {
  local cluster="${DEFAULT_CLUSTER}"
  local app_configs_dir="${DEFAULT_APP_CONFIGS_DIR}"
  local db_ssh_target=""
  local db_node_ip=""
  local apply=0
  local cluster_seen=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --app-configs-dir)
        app_configs_dir="${2:-}"
        shift 2
        ;;
      --db-ssh-target)
        db_ssh_target="${2:-}"
        shift 2
        ;;
      --db-node-ip)
        db_node_ip="${2:-}"
        shift 2
        ;;
      --apply)
        apply=1
        shift
        ;;
      --dry-run)
        apply=0
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      --*)
        die "unknown configure-demo-apps option: $1"
        ;;
      *)
        if [[ "${cluster_seen}" -eq 1 ]]; then
          die "unexpected configure-demo-apps argument: $1"
        fi
        cluster="$1"
        cluster_seen=1
        shift
        ;;
    esac
  done

  validate_cluster_name "${cluster}"
  [[ -d "${app_configs_dir}" ]] || die "KADM app configs directory not found: ${app_configs_dir}"
  local hello_secret_file="${app_configs_dir}/apps/demo-hello/base/secret.example.yaml"
  local hello_rollout_file="${app_configs_dir}/apps/demo-hello/base/rollout.yaml"
  local spring_secret_file="${app_configs_dir}/apps/demo-hello-spring/base/secret.example.yaml"
  local spring_rollout_file="${app_configs_dir}/apps/demo-hello-spring/base/rollout.yaml"
  [[ -f "${hello_secret_file}" ]] || die "demo hello secret file not found: ${hello_secret_file}"
  [[ -f "${hello_rollout_file}" ]] || die "demo hello rollout file not found: ${hello_rollout_file}"
  [[ -f "${spring_secret_file}" ]] || die "demo hello spring secret file not found: ${spring_secret_file}"
  [[ -f "${spring_rollout_file}" ]] || die "demo hello spring rollout file not found: ${spring_rollout_file}"

  if [[ -z "${db_node_ip}" ]]; then
    db_node_ip="$(extract_rollout_env_value "${hello_rollout_file}" "DB_HOST")"
  fi
  [[ -n "${db_node_ip}" ]] || die "db node ip could not be determined"
  validate_optional_machine_value "db node ip" "${db_node_ip}"
  if [[ -n "${db_ssh_target}" ]]; then
    validate_ssh_target "${db_ssh_target}"
  fi

  load_profile "${cluster}"

  if [[ "${apply}" -ne 1 ]]; then
    info "DRY RUN: no demo app dependencies will be configured"
    info "cluster: ${CLUSTER_NAME}"
    info "app configs: ${app_configs_dir}"
    info "db node ip: ${db_node_ip}"
    info "db ssh target: ${db_ssh_target:-auto-detect}"
    info "creates: apps/hello-db"
    info "creates: apps/hellospring-db"
    return 0
  fi

  require_command kubectl
  [[ -f "${KUBECONFIG_PATH}" ]] || die "kubeconfig not found: ${KUBECONFIG_PATH}"

  local tunnel_pid
  if is_local_ssh_target "${MASTER_SSH}" || is_local_address "${MASTER_PRIVATE_IP:-}"; then
    info "Using local Kubernetes API access"
    tunnel_pid=""
  else
    require_command ssh
    tunnel_pid="$(start_api_tunnel "${MASTER_SSH}" "${API_LOCAL_PORT}")"
  fi
  wait_for_kube_api "${KUBECONFIG_PATH}" "${tunnel_pid}"

  create_namespace_if_missing "${KUBECONFIG_PATH}" apps
  apply_delivery_yaml "${KUBECONFIG_PATH}" < "${hello_secret_file}"
  apply_delivery_yaml "${KUBECONFIG_PATH}" < "${spring_secret_file}"

  if [[ -z "${db_ssh_target}" ]]; then
    local db_external_ip
    db_external_ip="$(kubectl_for "${KUBECONFIG_PATH}" get nodes -o jsonpath='{range .items[*]}{range .status.addresses[*]}{.type}={.address}{","}{end}{"\n"}{end}' | awk -F, -v ip="${db_node_ip}" '
      {
        internal=""
        external=""
        for (i = 1; i <= NF; i++) {
          if ($i ~ /^InternalIP=/) internal=substr($i, 12)
          if ($i ~ /^ExternalIP=/) external=substr($i, 12)
        }
        if (internal == ip && external != "") { print external; exit }
      }'
    )"
    [[ -n "${db_external_ip}" ]] || die "failed to resolve database node external ip for ${db_node_ip}"
    db_ssh_target="root@${db_external_ip}"
  fi

  configure_mysql_demo_app "${db_ssh_target}" "${hello_secret_file}"
  configure_mysql_demo_app "${db_ssh_target}" "${spring_secret_file}"

  kubectl_retry "${KUBECONFIG_PATH}" -n apps delete pod -l app.kubernetes.io/name=hello --ignore-not-found
  kubectl_retry "${KUBECONFIG_PATH}" -n apps delete pod -l app.kubernetes.io/name=hellospring --ignore-not-found
  wait_for_labeled_pods_ready "${KUBECONFIG_PATH}" apps "app.kubernetes.io/name=hello" 300
  wait_for_labeled_pods_ready "${KUBECONFIG_PATH}" apps "app.kubernetes.io/name=hellospring" 300

  stop_pid "${tunnel_pid}"
  info "demo app dependencies configured"
}

cmd_configure_cluster_dns() {
  local cluster="${DEFAULT_CLUSTER}"
  local apply=0
  local cluster_seen=0
  local upstreams=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --upstream)
        upstreams+=("${2:-}")
        shift 2
        ;;
      --apply)
        apply=1
        shift
        ;;
      --dry-run)
        apply=0
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      --*)
        die "unknown configure-cluster-dns option: $1"
        ;;
      *)
        if [[ "${cluster_seen}" -eq 1 ]]; then
          die "unexpected configure-cluster-dns argument: $1"
        fi
        cluster="$1"
        cluster_seen=1
        shift
        ;;
    esac
  done

  validate_cluster_name "${cluster}"
  [[ "${#upstreams[@]}" -gt 0 ]] || upstreams=("1.1.1.1" "8.8.8.8")
  load_profile "${cluster}"

  if [[ "${apply}" -ne 1 ]]; then
    info "DRY RUN: cluster DNS configuration will not be changed"
    info "cluster: ${CLUSTER_NAME}"
    info "upstreams: ${upstreams[*]}"
    return 0
  fi

  require_command kubectl
  [[ -f "${KUBECONFIG_PATH}" ]] || die "kubeconfig not found: ${KUBECONFIG_PATH}"

  local tunnel_pid
  if is_local_ssh_target "${MASTER_SSH}" || is_local_address "${MASTER_PRIVATE_IP:-}"; then
    info "Using local Kubernetes API access"
    tunnel_pid=""
  else
    require_command ssh
    tunnel_pid="$(start_api_tunnel "${MASTER_SSH}" "${API_LOCAL_PORT}")"
  fi
  wait_for_kube_api "${KUBECONFIG_PATH}" "${tunnel_pid}"

  apply_cluster_dns_upstreams "${KUBECONFIG_PATH}" "$(current_coredns_nodehosts "${KUBECONFIG_PATH}")" "${upstreams[@]}"

  stop_pid "${tunnel_pid}"
  info "cluster dns configured"
}

main() {
  local command="${1:-help}"
  if [[ $# -gt 0 ]]; then
    shift
  fi

  case "${command}" in
    bootstrap)
      cmd_bootstrap "$@"
      ;;
    deploy)
      cmd_deploy "$@"
      ;;
    install-tools)
      cmd_install_tools "$@"
      ;;
    reset-node)
      cmd_reset_node "$@"
      ;;
    prepare-assets)
      cmd_prepare_assets "$@"
      ;;
    export-assets)
      cmd_export_assets "$@"
      ;;
    import-assets)
      cmd_import_assets "$@"
      ;;
    publish-release-console)
      cmd_publish_release_console "$@"
      ;;
    publish-onecd)
      cmd_publish_release_console "$@"
      ;;
    configure-delivery)
      cmd_configure_delivery "$@"
      ;;
    connect)
      cmd_connect "$@"
      ;;
    status)
      cmd_status "$@"
      ;;
    cleanup-legacy-onecd)
      cmd_cleanup_legacy_onecd "$@"
      ;;
    configure-demo-apps)
      cmd_configure_demo_apps "$@"
      ;;
    configure-cluster-dns)
      cmd_configure_cluster_dns "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      die "unknown command: ${command}"
      ;;
  esac
}

main "$@"

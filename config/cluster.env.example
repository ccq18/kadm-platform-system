# Example ClusterSpec input for the platform fixed growth path.
# This file is safe to commit because it does not contain real secrets.
# 示例配置不包含真实密钥，只能保留 secret ref 或占位值。
# Copy it to a local ignored file before filling real values.

# Safety switch used by later scripts. Runtime automation must default to DRY_RUN=1.
DRY_RUN=1

# Cluster identity.
CLUSTER_ID=cluster-001
CLUSTER_NAME=example-self-hosted
ENVIRONMENT=production

# Kubernetes and platform versions. Verify actual versions before implementation.
K3S_VERSION=v1.30.x+k3s1
CILIUM_VERSION=1.16.x
ARGO_CD_VERSION=2.x
ARGO_ROLLOUTS_VERSION=1.x
CERT_MANAGER_VERSION=1.x

# K3s networking. These values must remain identical on all Server nodes.
CLUSTER_CIDR=10.32.0.0/16
SERVICE_CIDR=10.48.0.0/16
CLUSTER_DNS=10.48.0.10
CLUSTER_DOMAIN=cluster.local

# API and certificate configuration.
API_SERVER_PORT=6443
TLS_SAN_1=example-k8s-api.internal
TLS_SAN_2=example-k8s-api.public

# Default self-hosted node plan.
SERVER1_NAME=server-1
SERVER1_PRIVATE_IP=10.0.0.11
SERVER1_PUBLIC_IP=203.0.113.11
SERVER2_NAME=server-2
SERVER2_PRIVATE_IP=10.0.0.12
SERVER2_PUBLIC_IP=203.0.113.12
SERVER3_NAME=server-3
SERVER3_PRIVATE_IP=10.0.0.13
SERVER3_PUBLIC_IP=203.0.113.13

# Gateway listener ports for node-direct entry.
GATEWAY_HTTP_PORT=8080
GATEWAY_HTTPS_PORT=8443
GATEWAY_CLASS_NAME=cilium
PUBLIC_GATEWAY_NAMESPACE=gateway-system
PUBLIC_GATEWAY_NAME=public-gateway

# Cilium defaults.
CILIUM_ROUTING_MODE=tunnel
CILIUM_TUNNEL_PROTOCOL=vxlan
CILIUM_OPERATOR_REPLICAS_SINGLE=1
CILIUM_OPERATOR_REPLICAS_HA=2

# Backup target. Use refs or local ignored files for real credentials.
BACKUP_PROVIDER=s3-compatible
BACKUP_BUCKET=example-k3s-etcd-backups
BACKUP_PREFIX=clusters/cluster-001
BACKUP_REGION=example-region
BACKUP_ENDPOINT=https://object-storage.example.com
BACKUP_ACCESS_KEY_REF=secret://example/object-storage-access-key
BACKUP_SECRET_KEY_REF=secret://example/object-storage-secret-key

# Sensitive references. Do not replace these with real secret values in git.
K3S_TOKEN_SECRET_REF=secret://example/k3s-token
SSH_PRIVATE_KEY_REF=secret://example/ssh-private-key
GITHUB_TOKEN_REF=secret://example/github-token
ARGOCD_TOKEN_REF=secret://example/argocd-token

# Application source repositories retained for the current phase.
DEMO_HELLO_REPO=git@github.com:ccq18/demo-hello.git
DEMO_HELLO_SPRING_REPO=git@github.com:ccq18/demo-hello-spring.git

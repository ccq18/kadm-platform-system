PORT=8080
ONECD_APPS_CONFIG=config/apps.example.json

# GitHub token with repo workflow dispatch access and read access to workflow runs.
GITHUB_TOKEN=ghp_replace_me

# Argo CD API base URL and API token.
ARGOCD_BASE_URL=https://argocd.example.com
ARGOCD_TOKEN=argocd_replace_me

# Optional for local development. In-cluster deployments use service account token discovery.
KUBE_API_SERVER=https://kubernetes.default.svc:443
KUBE_TOKEN=
